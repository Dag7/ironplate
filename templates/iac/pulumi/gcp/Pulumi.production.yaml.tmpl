# =============================================================================
# {{ .Project.Metadata.Name }} Production Environment Configuration
# =============================================================================
# Production-grade configuration with high availability, security hardening,
# and redundancy enabled.
# =============================================================================
#
# KUBECTL ACCESS:
#   gcloud container clusters get-credentials {{ .Project.Metadata.Name }}-production-cluster --region us-central1 --project {{ .Project.Metadata.Name }}-production
#
# PULUMI OUTPUTS (after deployment):
#   pulumi stack output gcloudGetCredentials -s production
#
# =============================================================================

config:
  # ---------------------------------------------------------------------------
  # GCP Project Settings
  # ---------------------------------------------------------------------------
  gcp:project: {{ .Project.Metadata.Name }}-production
  gcp:region: us-central1
  gcp:zone: us-central1-a
  # Required for Billing Budgets API when using ADC (Application Default Credentials)
  gcp:userProjectOverride: "true"
  gcp:billingProject: {{ .Project.Metadata.Name }}-production
  # ---------------------------------------------------------------------------
  # Environment
  # ---------------------------------------------------------------------------
  # Short name for resource naming (3-4 chars, used in service account names)
  # Examples: stg (staging), prd (production), tst (test), dev (development)
  {{ .Project.Metadata.Name }}:envShortName: prd
  # ---------------------------------------------------------------------------
  # Organization
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:organization: {{ .Project.Metadata.Organization }}
  {{ .Project.Metadata.Name }}:zone: us-central1-a
  {{ .Project.Metadata.Name }}:team: platform
  {{ .Project.Metadata.Name }}:deletionProtection: "true"
  # ---------------------------------------------------------------------------
  # Networking
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:networking:
    vpcCidr: "10.20.0.0/16"
    gkeSubnetCidr: "10.20.0.0/20"
    # /14 CIDR must be aligned (start at x.0.0.0 where x divisible by 4)
    podsCidr: "10.72.0.0/14"
    servicesCidr: "10.76.0.0/20"
    privateServicesCidr: "10.20.48.0/20"
    enableCloudNat: true
  # ---------------------------------------------------------------------------
  # GKE Configuration
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:gke:
    releaseChannel: STABLE
    enableAutopilot: false
    enablePrivateCluster: true
    enablePrivateEndpoint: false
    enableWorkloadIdentity: true
    enableBinaryAuthorization: true
    enableNetworkPolicy: true
    enableVpa: true
    enableHttpLoadBalancing: true
    enableHpa: true
    # Master Authorized Networks - Controls who can access kubectl/API
    # TODO: After setup, restrict to your IP + CI/CD IPs for better security
    masterAuthorizedNetworks:
      - displayName: "Allow All (Initial Setup)"
        cidrBlock: "0.0.0.0/0"
    # Maintenance window: Sat-Sun 00:00-12:00 UTC
    maintenanceWindow:
      startTime: "2025-01-04T00:00:00Z"
      endTime: "2025-01-04T12:00:00Z"
      recurrence: "FREQ=WEEKLY;BYDAY=SA,SU"
    # -------------------------------------------------------------------------
    # NODE POOLS (Production: Higher specs, no spot instances)
    # -------------------------------------------------------------------------
    # 3 pools with clear separation:
    #   - system: Critical k8s components only (kube-system)
    #   - infra: Infrastructure workloads (observability, databases, ingress)
    #   - services: Application workloads (microservices) - on-demand for stability
    #
    # Using e2-standard-4 (4 vCPU, 16GB) for better bin-packing:
    #   - Less CPU fragmentation
    #   - Less node overhead (fewer nodes = less kubelet/kube-proxy overhead)
    #   - Easier scheduling for larger pods
    #
    # Regional cluster: minNodes/maxNodes is PER ZONE (3 zones)
    #   - infra: 1-3 per zone = 3-9 nodes total
    #   - services: 1-4 per zone = 3-12 nodes total
    # -------------------------------------------------------------------------
    nodePools:
      # System pool - k8s control plane addons only
      - name: system
        machineType: e2-small
        minNodes: 1
        maxNodes: 3
        initialNodes: 1
        diskSizeGb: 30
        diskType: pd-standard
        spot: false
        labels:
          workload-type: system
        taints:
          - key: CriticalAddonsOnly
            value: "true"
            effect: NO_SCHEDULE
      # Infra pool - infrastructure workloads (stable, non-spot)
      # Using e2-standard-4 for better bin-packing and less fragmentation
      - name: infra
        machineType: e2-standard-4
        minNodes: 1
        maxNodes: 3
        initialNodes: 1
        diskSizeGb: 30
        diskType: pd-ssd
        spot: false
        labels:
          workload-type: infra
        taints:
          - key: workload-type
            value: infra
            effect: NO_SCHEDULE
      # Services pool - application microservices (on-demand for production stability)
      # Using e2-standard-4 for better bin-packing and less fragmentation
      - name: services
        machineType: e2-standard-4
        minNodes: 1
        maxNodes: 4
        initialNodes: 1
        diskSizeGb: 50
        diskType: pd-standard
        spot: false
        labels:
          workload-type: services
  # ---------------------------------------------------------------------------
  # Database Configuration (Production: Dedicated CPU, HA-ready)
  # ---------------------------------------------------------------------------
  # TIER OPTIONS (ENTERPRISE edition):
  #   Shared CPU (not recommended for production):
  #     - db-f1-micro    : shared CPU, 0.6 GB  (~$7/month)
  #     - db-g1-small    : shared CPU, 1.7 GB  (~$25/month)
  #   Dedicated CPU (production-ready):
  #     - db-custom-1-3840 : 1 vCPU, 3.75 GB  (~$35/month)  <- current
  #     - db-custom-2-7680 : 2 vCPU, 7.5 GB   (~$70/month)  <- scale up when needed
  #     - db-custom-4-15360: 4 vCPU, 15 GB    (~$140/month)
  # To upgrade to ENTERPRISE_PLUS (advanced features): use db-perf-optimized-N-*
  # To enable HA: set highAvailability: true (doubles cost)
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:database:
    edition: ENTERPRISE
    tier: db-custom-1-3840
    highAvailability: false
    diskSizeGb: 20
    diskAutoresize: true
    diskAutoresizeLimit: 100
    postgresVersion: POSTGRES_17
    enablePointInTimeRecovery: true
    backupRetentionDays: 14
    deletionProtection: true
    databaseFlags:
      max_connections: "500"
      log_checkpoints: "on"
      log_connections: "on"
    maintenanceWindow:
      day: 7
      hour: 4
    insightsConfig:
      queryInsightsEnabled: true
      queryStringLength: 1024
      recordApplicationTags: true
      recordClientAddress: true
{{- if .Computed.HasRedis }}
  # ---------------------------------------------------------------------------
  # Redis Configuration (Production: Start with BASIC, upgrade to HA when needed)
  # ---------------------------------------------------------------------------
  # TIER OPTIONS:
  #   - BASIC       : no HA, single node (~$35/month for 1GB)  <- current
  #   - STANDARD_HA : HA with replica  (~$70/month for 1GB, doubles cost)
  # To enable HA: change tier to STANDARD_HA
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:redis:
    tier: BASIC
    memorySizeGb: 1
    redisVersion: REDIS_7_0
    authEnabled: true
    transitEncryptionEnabled: true
    redisConfigs:
      maxmemory-policy: allkeys-lru
      notify-keyspace-events: Ex
    maintenanceWindow:
      day: SUNDAY
      startTime:
        hours: 4
        minutes: 0
{{- end }}
{{- if .Computed.HasKafka }}
  # ---------------------------------------------------------------------------
  # Kafka Configuration
  # ---------------------------------------------------------------------------
  # NOTE: Kafka is deployed via Helm (Strimzi), NOT Pulumi.
  # Configuration is in: k8s/helm/strimzi-kafka/values-prod.yaml
  # Deployed by Tilt/ArgoCD: setup_kafka("production")
  # ---------------------------------------------------------------------------
{{- end }}

  # ---------------------------------------------------------------------------
  # Storage Buckets (with lifecycle policies)
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:storage:
    buckets:
      - nameSuffix: artifacts
        storageClass: STANDARD
        location: us-central1
        versioning: true
        uniformBucketLevelAccess: true
        lifecycleRules:
          - action:
              type: SetStorageClass
              storageClass: NEARLINE
            condition:
              age: 30
          - action:
              type: Delete
            condition:
              age: 365
      - nameSuffix: files
        storageClass: STANDARD
        location: us-central1
        versioning: true
        uniformBucketLevelAccess: true
        lifecycleRules:
          # Move to cheaper storage after 90 days of no access
          # No auto-delete - customer files are retained indefinitely
          - action:
              type: SetStorageClass
              storageClass: NEARLINE
            condition:
              age: 90
          - action:
              type: SetStorageClass
              storageClass: COLDLINE
            condition:
              age: 365
        cors:
          - origins:
              - "https://{{ .Project.Metadata.Domain }}"
              - "https://app.{{ .Project.Metadata.Domain }}"
            methods:
              - GET
              - PUT
              - POST
              - DELETE
              - HEAD
            responseHeaders:
              - Content-Type
              - Content-Length
              - Content-MD5
              - x-goog-resumable
            maxAgeSeconds: 3600
      - nameSuffix: backups
        storageClass: NEARLINE
        location: us
        versioning: true
        uniformBucketLevelAccess: true
        lifecycleRules:
          - action:
              type: SetStorageClass
              storageClass: COLDLINE
            condition:
              age: 90
          - action:
              type: Delete
            condition:
              age: 365
{{- if .Computed.HasObservability }}
      - nameSuffix: tempo-traces
        storageClass: STANDARD
        location: us-central1
        versioning: false
        uniformBucketLevelAccess: true
        lifecycleRules:
          - action:
              type: SetStorageClass
              storageClass: NEARLINE
            condition:
              age: 7
          - action:
              type: Delete
            condition:
              age: 30
{{- end }}
{{- if .Computed.HasLangfuse }}
      - nameSuffix: langfuse-blob
        storageClass: STANDARD
        location: us-central1
        versioning: true
        uniformBucketLevelAccess: true
        lifecycleRules:
          - action:
              type: SetStorageClass
              storageClass: NEARLINE
            condition:
              age: 90
          - action:
              type: Delete
            condition:
              age: 730
{{- end }}
  # ---------------------------------------------------------------------------
  # Domain Configuration (Production)
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:domain:
    baseDomain: {{ .Project.Metadata.Domain }}
    # envSubdomain is empty for production (*.domain, not *.staging.domain)
    tlsSecretName: {{ .Project.Metadata.Name }}-production-tls
    appSubdomain: app
    apiSubdomain: api
    authSubdomain: auth
    tlsEnabled: true
    tlsIssuer: letsencrypt-production
    enableHsts: true
  # ---------------------------------------------------------------------------
  # Certificate Configuration (cert-manager)
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:certificate:
    enabled: true
    name: {{ .Project.Metadata.Name }}-production-wildcard
    domains:
      - {{ .Project.Metadata.Domain }}
      - "*.{{ .Project.Metadata.Domain }}"
  # ---------------------------------------------------------------------------
  # Traefik Ingress Controller Configuration
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:traefik:
    replicas: 2
    resources:
      requests:
        cpu: 200m
        memory: 256Mi
      limits:
        cpu: 1000m
        memory: 1Gi
    autoscaling:
      enabled: true
      minReplicas: 2
      maxReplicas: 5
      targetCpuUtilization: 60
    logLevel: WARN
  # ---------------------------------------------------------------------------
  # DNS Configuration
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:dns:
    domain: {{ .Project.Metadata.Domain }}
    acmeEmail: admin@{{ .Project.Metadata.Domain }}
    enableDnssec: true
  # ---------------------------------------------------------------------------
  # Security Configuration (Hardened)
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:security:
    cloudArmor:
      enabled: true
      enablePlusTier: false
      rateLimitPerIp: 1000
      authRateLimitPerIp: 30
    iap:
      enabled: true
      supportEmail: admin@{{ .Project.Metadata.Domain }}
      allowedMembers:
        domain: {{ .Project.Metadata.Domain }}
      oauth2ProxyVersion: "v7.5.1"
      allowedEmailDomain: {{ .Project.Metadata.Domain }}
      replicas: 2
      cookieDomain: .{{ .Project.Metadata.Domain }}
      cookieRefresh: 30m
      cookieExpire: 2h
      cookieSameSiteStrict: false
      enablePodAntiAffinity: true
      nodeSelector:
        workload-type: infra
      tolerations:
        - key: workload-type
          operator: Equal
          value: infra
          effect: NoSchedule
      resources:
        requests:
          cpu: 100m
          memory: 128Mi
        limits:
          cpu: 500m
          memory: 256Mi
  # ---------------------------------------------------------------------------
  # Load Balancer Configuration
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:loadBalancer:
    enabled: true
{{- if .Computed.HasExternalSecrets }}
  # ---------------------------------------------------------------------------
  # Secrets Configuration
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:secrets:
    enableExternalSecrets: true
    refreshInterval: 1h
    clusterSecretStoreName: gcp-secret-manager
{{- end }}
{{- if .Computed.HasObservability }}
  # ---------------------------------------------------------------------------
  # Observability Configuration (Production-grade)
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:observability:
    enableOtel: true
    enableTempo: true
    tempoStorageBackend: gcs
    tempoStorageBucket: {{ .Project.Metadata.Name }}-production-tempo-traces
    traceRetentionHours: 720
    enablePrometheus: true
{{- end }}
{{- if .Computed.HasLangfuse }}
  # ---------------------------------------------------------------------------
  # Langfuse Configuration
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:langfuse:
    selfHosted: true
    version: "3.0.0"
    redis:
      tier: STANDARD_HA
      memorySizeGb: 2
      redisVersion: REDIS_7_0
      authEnabled: true
      transitEncryptionEnabled: true
      redisConfigs:
        maxmemory-policy: noeviction
{{- end }}
  # ---------------------------------------------------------------------------
  # GitHub CI/CD Configuration (Workload Identity)
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:github:
    organization: {{ .Project.Metadata.Organization }}
    repository: {{ .Project.Metadata.Name }}
    allowedBranches:
      - main
      - production
{{- if .Computed.HasArgoCD }}
  # ---------------------------------------------------------------------------
  # ArgoCD Configuration (Production)
  # ---------------------------------------------------------------------------
  # IMPORTANT: Production uses MANUAL sync by default for safety.
  # ---------------------------------------------------------------------------
  {{ .Project.Metadata.Name }}:argocd:
    enabled: true
    version: "9.4.2"
    subdomain: argocd
    replicas: 2
    enableSso: false
    enableIap: true
    useInfraNodes: true
    webhook:
      enabled: true
    notifications:
      enabled: true
      slackChannel: "#{{ .Project.Metadata.Name }}-deployments"
      slackAlertChannel: "#{{ .Project.Metadata.Name }}-alerts"
    imageUpdater:
      enabled: true
      version: "1.0.4"
      registryPrefix: us-central1-docker.pkg.dev/{{ .Project.Metadata.Name }}-production/{{ .Project.Metadata.Name }}
      updateStrategy: digest
      writeBackMethod: git
      writeBackBranch: main
      authStrategy: workload-identity-script
    rbac:
      defaultPolicy: ""
      adminGroups:
        - argocd-admins@{{ .Project.Metadata.Domain }}
        - platform-team@{{ .Project.Metadata.Domain }}
      developerGroups:
        - devops@{{ .Project.Metadata.Domain }}
      viewerGroups:
        - engineering@{{ .Project.Metadata.Domain }}
      enableGoogleGroups: true
    serverResources:
      requests:
        cpu: 200m
        memory: 256Mi
      limits:
        cpu: 1000m
        memory: 1Gi
    controllerResources:
      requests:
        cpu: 500m
        memory: 512Mi
      limits:
        cpu: 2000m
        memory: 2Gi
    repoServerResources:
      requests:
        cpu: 200m
        memory: 256Mi
      limits:
        cpu: 1000m
        memory: 1Gi
    applicationSetReplicas: 2
    pdbEnabled: true
    redisHa: true
    enableSyncWindows: false
    logLevel: info
{{- end }}
