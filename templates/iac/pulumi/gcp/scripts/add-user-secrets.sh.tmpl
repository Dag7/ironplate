#!/bin/bash
# =============================================================================
# Add User-Provided Secrets to GCP Secret Manager
# =============================================================================
# This script creates placeholder secrets in GCP Secret Manager that are
# referenced by the ExternalSecret resources in the Kustomize overlays.
#
# Usage:
#   ./scripts/add-user-secrets.sh staging
#   ./scripts/add-user-secrets.sh production
#
# After running this script, update the secrets with real values:
#   gcloud secrets versions add {{ .Project.Metadata.Name }}-{env}-SECRET_NAME --data-file=-
# =============================================================================

set -e

ENV=${1:-staging}

if [[ "$ENV" != "staging" && "$ENV" != "production" ]]; then
  echo "Usage: $0 <staging|production>"
  exit 1
fi

PROJECT="{{ .Project.Metadata.Name }}-${ENV}"
echo "Creating user-provided secrets in project: ${PROJECT}"

# List of user-provided secrets
SECRETS=(
  # OAuth Credentials
  "{{ .Project.Metadata.Name }}-${ENV}-google-client-id"
  "{{ .Project.Metadata.Name }}-${ENV}-google-client-secret"
  "{{ .Project.Metadata.Name }}-${ENV}-github-client-id"
  "{{ .Project.Metadata.Name }}-${ENV}-github-client-secret"

  # LLM API Keys
  "{{ .Project.Metadata.Name }}-${ENV}-openai-api-key"
  "{{ .Project.Metadata.Name }}-${ENV}-anthropic-api-key"
  "{{ .Project.Metadata.Name }}-${ENV}-google-api-key"
{{ if .Computed.HasHasura }}
  # Hasura
  "{{ .Project.Metadata.Name }}-${ENV}-hasura-admin-secret"
  "{{ .Project.Metadata.Name }}-${ENV}-hasura-jwt-secret"
{{ end }}{{ if .Computed.HasLangfuse }}
  # Langfuse
  "{{ .Project.Metadata.Name }}-${ENV}-langfuse-public-key"
  "{{ .Project.Metadata.Name }}-${ENV}-langfuse-secret-key"
  "{{ .Project.Metadata.Name }}-${ENV}-langfuse-base-url"
{{ end }})

for SECRET in "${SECRETS[@]}"; do
  echo "Creating secret: ${SECRET}"

  # Check if secret already exists
  if gcloud secrets describe "${SECRET}" --project="${PROJECT}" &>/dev/null; then
    echo "  → Secret already exists, skipping"
  else
    # Create secret with placeholder value
    echo "PLACEHOLDER_VALUE" | gcloud secrets create "${SECRET}" \
      --project="${PROJECT}" \
      --replication-policy="automatic" \
      --data-file=- \
      --labels="environment=${ENV},managed-by=manual,type=user-provided"
    echo "  → Created with placeholder value"
  fi
done

echo ""
echo "=========================================="
echo "User-provided secrets created!"
echo "=========================================="
echo ""
echo "Next steps:"
echo "1. Update each secret with the real value:"
echo "   echo 'YOUR_VALUE' | gcloud secrets versions add SECRET_NAME --project=${PROJECT} --data-file=-"
echo ""
echo "2. Or use the GCP Console:"
echo "   https://console.cloud.google.com/security/secret-manager?project=${PROJECT}"
echo ""
echo "Required secrets to configure:"
echo "  - OAuth: Google and GitHub client credentials"
echo "  - LLM: OpenAI, Anthropic, Google API keys"
{{ if .Computed.HasHasura -}}
echo "  - Hasura: Admin secret and JWT secret"
{{ end -}}
{{ if .Computed.HasLangfuse -}}
echo "  - Langfuse: Keys for LLM observability (optional)"
{{ end -}}
