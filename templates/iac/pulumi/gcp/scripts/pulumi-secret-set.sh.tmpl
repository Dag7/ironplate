#!/usr/bin/env bash
set -euo pipefail

# ════════════════════════════════════════════════════════════════════════════
#  pulumi-secret-set.sh
#
#  Sets Pulumi secrets from a single consolidated JSON file.
#  Each top-level key in the JSON becomes a separate Pulumi secret.
#
#  This is fully dynamic - no need to define credential groups in advance.
#  The script simply iterates over all top-level keys in the JSON.
#
#  Usage:
#    ./scripts/pulumi-secret-set.sh -e staging
#    ./scripts/pulumi-secret-set.sh -e production
#
#  File Structure:
#    src/_secrets/
#    ├── template.json      # Template with placeholder values
#    ├── staging.json       # Staging secrets (gitignored)
#    └── production.json    # Production secrets (gitignored)
#
#  JSON File Format:
#    {
#      "jwt-credentials": {
#        "jwt-secret": "xxx",
#        "jwt-issuer": "{{ .Project.Metadata.Name }}"
#      },
#      "github-app-credentials": {
#        "appId": "123",
#        "installationId": "456",
#        "privateKey": "-----BEGIN RSA..."
#      }
#    }
#
#  Result in Pulumi.staging.yaml:
#    {{ .Project.Metadata.Name }}:jwt-credentials:
#      secure: v1:encrypted_json...
#    {{ .Project.Metadata.Name }}:github-app-credentials:
#      secure: v1:encrypted_json...
#
# ════════════════════════════════════════════════════════════════════════════

# ANSI color codes
readonly RESET="\033[0m"
readonly BOLD="\033[1m"
readonly GREEN="\033[32m"
readonly YELLOW="\033[33m"
readonly RED="\033[31m"
readonly CYAN="\033[36m"

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PULUMI_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
SECRETS_DIR="$PULUMI_DIR/src/_secrets"

function usage() {
  cat <<EOF
${BOLD}{{ .Project.Metadata.Name }} Pulumi Secret Setter${RESET}

${BOLD}Usage:${RESET}
  $0 -e ENVIRONMENT    Set all secrets from {env}.json
  $0 -h                Show this help message

${BOLD}Options:${RESET}
  -e ENVIRONMENT   Environment name (staging or production)
  -h               Show this help message

${BOLD}File Structure:${RESET}
  src/_secrets/
  ├── template.json      # Template with placeholder values
  ├── staging.json       # Staging secrets
  └── production.json    # Production secrets

${BOLD}JSON Format:${RESET}
  {
    "jwt-credentials": {
      "jwt-secret": "your-secret",
      "jwt-issuer": "{{ .Project.Metadata.Name }}"
    },
    "github-app-credentials": {
      "appId": "123456",
      "installationId": "12345678",
      "privateKey": "-----BEGIN RSA PRIVATE KEY-----\\n..."
    },
    ...
  }

${BOLD}Result:${RESET}
  Each top-level key becomes a separate Pulumi secret:
    {{ .Project.Metadata.Name }}:jwt-credentials: { secure: v1:encrypted... }
    {{ .Project.Metadata.Name }}:github-app-credentials: { secure: v1:encrypted... }

${BOLD}Notes:${RESET}
  - Empty values and REPLACE_WITH_* placeholders are filtered out
  - Groups with no valid secrets after filtering are skipped
  - The script is fully dynamic - no need to predefine credential groups
EOF
  exit 0
}

function error() {
  echo -e "${RED}Error:${RESET} $1" >&2
  exit 1
}

function info() {
  echo -e "${CYAN}→${RESET} $1"
}

function success() {
  echo -e "${GREEN}✓${RESET} $1"
}

function warn() {
  echo -e "${YELLOW}⚠${RESET} $1"
}

# Check if Pulumi CLI is available
function check_pulumi() {
  if ! command -v pulumi &>/dev/null; then
    error "Pulumi CLI not found. Please install it first."
  fi

  if ! pulumi whoami &>/dev/null; then
    error "Not logged into Pulumi. Run 'pulumi login' first."
  fi
}

# Check if jq is available
function check_jq() {
  if ! command -v jq &>/dev/null; then
    error "jq is required but not installed. Install with: apt-get install jq"
  fi
}

# Process the consolidated secrets file
function process_secrets_file() {
  local env="$1"
  local file="$SECRETS_DIR/$env.json"

  if [[ ! -f "$file" ]]; then
    error "Secrets file not found: $file

Create it by copying from template:
  cp $SECRETS_DIR/credentials.template.json $file

Then edit with your actual values."
  fi

  # Validate JSON
  if ! jq empty "$file" 2>/dev/null; then
    error "Invalid JSON in file: $file"
  fi

  # Get all top-level keys (credential groups)
  local groups
  groups=$(jq -r 'keys[]' "$file")

  if [[ -z "$groups" ]]; then
    error "No credential groups found in $file"
  fi

  echo -e "${BOLD}Processing secrets for $env environment...${RESET}"
  echo -e "File: $file"
  echo ""

  local groups_processed=0
  local groups_skipped=0

  for group in $groups; do
    info "Processing: $group"

    # Extract the group's JSON object
    local group_json
    group_json=$(jq -c ".\"$group\"" "$file")

    # Count keys before filtering
    local count
    count=$(echo "$group_json" | jq 'length')

    # Filter out empty values and placeholders
    local filtered_json
    filtered_json=$(echo "$group_json" | jq -c 'with_entries(select(
      .value != null and
      .value != "" and
      (.value | tostring | test("^REPLACE_WITH_|^missing-secret$|^TODO:|^CHANGE_ME$") | not)
    ))')

    local filtered_count
    filtered_count=$(echo "$filtered_json" | jq 'length')

    if [[ "$filtered_count" -eq 0 ]]; then
      warn "  Skipped: all values empty or placeholders"
      ((++groups_skipped))
      continue
    fi

    if [[ "$filtered_count" -lt "$count" ]]; then
      local skipped=$((count - filtered_count))
      warn "  Filtered out $skipped empty/placeholder values"
    fi

    # Set the Pulumi secret
    local key="{{ .Project.Metadata.Name }}:$group"
    pulumi config set "$key" --secret "$filtered_json"
    success "  Set $key ($filtered_count keys)"

    ((++groups_processed))
  done

  echo ""
  echo -e "${GREEN}═══════════════════════════════════════════════════════════════${RESET}"
  echo -e "${GREEN}✓ Processed $groups_processed credential groups${RESET}"
  if [[ "$groups_skipped" -gt 0 ]]; then
    echo -e "${YELLOW}⚠ Skipped $groups_skipped empty groups${RESET}"
  fi
  echo -e "${GREEN}═══════════════════════════════════════════════════════════════${RESET}"
  echo ""
  echo "Next steps:"
  echo "  1. Review: pulumi config"
  echo "  2. Preview: pulumi preview"
  echo "  3. Deploy: pulumi up"
}

# Parse arguments
ENVIRONMENT=""

while getopts ":e:h" opt; do
  case "$opt" in
    e) ENVIRONMENT="$OPTARG" ;;
    h) usage ;;
    :) error "Option -$OPTARG requires an argument." ;;
    *) error "Unknown option: -$OPTARG" ;;
  esac
done

# Validate arguments
if [[ -z "$ENVIRONMENT" ]]; then
  usage
fi

if [[ "$ENVIRONMENT" != "staging" && "$ENVIRONMENT" != "production" ]]; then
  error "Environment must be 'staging' or 'production'"
fi

# Check dependencies
check_pulumi
check_jq

# Change to Pulumi directory and select stack
cd "$PULUMI_DIR"

info "Selecting Pulumi stack: $ENVIRONMENT"
if ! pulumi stack select "$ENVIRONMENT" 2>/dev/null; then
  error "Stack '$ENVIRONMENT' not found. Run 'pulumi stack init $ENVIRONMENT' first."
fi
success "Selected stack: $ENVIRONMENT"
echo ""

# Process the secrets file
process_secrets_file "$ENVIRONMENT"
