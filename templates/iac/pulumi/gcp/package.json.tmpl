{
  "name": "@{{ .Project.Metadata.Organization }}/iac",
  "version": "1.0.0",
  "description": "{{ .Project.Metadata.Name }} Infrastructure as Code - GCP/GKE with Pulumi",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "preview": "pulumi preview",
    "up": "pulumi up",
    "destroy": "pulumi destroy",
    "stack:staging": "pulumi stack select staging",
    "stack:production": "pulumi stack select production",
    "preview:staging": "npm run stack:staging && pulumi preview",
    "preview:production": "npm run stack:production && pulumi preview",
    "up:staging": "npm run stack:staging && pulumi up",
    "up:production": "npm run stack:production && pulumi up",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pulumi/gcp": "^9.9.0",
    "@pulumi/kubernetes": "^4.0.0",
    "@pulumi/pulumi": "^3.0.0",
    "@pulumi/random": "^4.0.0",
    "@pulumi/tls": "^5.0.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
