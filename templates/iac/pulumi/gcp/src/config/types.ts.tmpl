/**
 * Secret credential groups -- each maps 1:1 with:
 * - JSON files in _secrets/{env}/*.json
 * - Kubernetes Secret resources
 * - GCP Secret Manager secrets
 */
export type SecretCredentialGroup =
  | "jwt-credentials"
  | "encryption-credentials"
  | "oauth-credentials"
  | "llm-credentials"
  | "email-credentials"
  | "iap-credentials"
  | "github-app-credentials"{{ if .Computed.HasHasura }}
  | "hasura-credentials"{{ end }}{{ if .Computed.HasLangfuse }}
  | "langfuse-credentials"
  | "langfuse-clickhouse-credentials"
  | "langfuse-redis-credentials"
  | "langfuse-otel-credentials"{{ end }}{{ if .Computed.HasObservability }}
  | "grafana-credentials"
  | "alertmanager-credentials"{{ end }}{{ if .Computed.HasArgoCD }}
  | "slack-credentials"{{ end }};

