/**
 * Map of credential group names to their typed interfaces.
 * Used for type-safe secret loading via Pulumi config.
 */
export interface CredentialGroupTypes {
  "jwt-credentials": JwtCredentials;
  "encryption-credentials": EncryptionCredentials;
  "oauth-credentials": OAuthCredentials;
  "llm-credentials": LlmCredentials;
  "email-credentials": EmailCredentials;
  "iap-credentials": IapCredentials;
  "github-app-credentials": GitHubAppSecretCredentials;{{ if .Computed.HasHasura }}
  "hasura-credentials": HasuraCredentials;{{ end }}{{ if .Computed.HasLangfuse }}
  "langfuse-credentials": LangfuseCredentials;
  "langfuse-clickhouse-credentials": LangfuseClickhouseCredentials;
  "langfuse-redis-credentials": LangfuseRedisCredentials;
  "langfuse-otel-credentials": LangfuseOtelCredentials;{{ end }}{{ if .Computed.HasObservability }}
  "grafana-credentials": GrafanaCredentials;
  "alertmanager-credentials": AlertmanagerCredentials;{{ end }}{{ if .Computed.HasArgoCD }}
  "slack-credentials": SlackCredentials;{{ end }}
}

/**
 * Nested secrets configuration.
 * Structure: {{ .Project.Metadata.Name }}:secrets:{group}:{key} = value
 *
 * Example in Pulumi.staging.yaml:
 *   {{ .Project.Metadata.Name }}:secrets:jwt-credentials:
 *     jwt-secret:
 *       secure: v1:encrypted...
 *
 * NOTE: Credentials are loaded via getSecretObject() which returns
 * pulumi.Output<T> to ensure values are marked as secrets and not logged.
 */
export type SecretsCredentials = {
  [K in SecretCredentialGroup]?:
    | pulumi.Output<CredentialGroupTypes[K]>
    | undefined;
};

/** External Secrets Operator and credential configuration */
export interface SecretsConfig {
  /** Enable External Secrets Operator for syncing secrets from GCP Secret Manager */
  enableExternalSecrets: boolean;
  /** Secret refresh interval (e.g., "1h", "30m") */
  refreshInterval: string;
  /** ClusterSecretStore name (referenced by ExternalSecret resources) */
  clusterSecretStoreName: string;
  /** Credential groups with their key-value pairs (as Pulumi secret outputs) */
  credentials?: SecretsCredentials;
}

