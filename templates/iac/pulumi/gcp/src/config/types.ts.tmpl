/**
 * {{ .Project.Metadata.Name }} Infrastructure Configuration Types
 *
 * These interfaces define the complete configuration schema for the
 * {{ .Project.Metadata.Name }} platform infrastructure on GCP.
 * They follow the Interface Segregation Principle -- each config section
 * is independent and can evolve without affecting other sections.
 */

import type * as pulumi from "@pulumi/pulumi";

// =============================================================================
// Environment Types
// =============================================================================

/**
 * Environment name -- not hardcoded to specific values.
 * Can be any string: "staging", "production", "test", "dev", etc.
 */
export type Environment = string;

/** GKE release channel determines automatic upgrade cadence */
export type GkeReleaseChannel = "RAPID" | "REGULAR" | "STABLE";

/** Redis tier -- BASIC (no replication) or STANDARD_HA (cross-zone replication) */
export type RedisTier = "BASIC" | "STANDARD_HA";

/** TLS certificate issuer -- staging for testing, production for real certs */
export type TlsIssuer = "letsencrypt-staging" | "letsencrypt-production";

// =============================================================================
// Networking Configuration
// =============================================================================

/** VPC and subnet CIDR configuration for the GCP project */
export interface NetworkingConfig {
  /** VPC CIDR block (e.g., 10.0.0.0/16) */
  vpcCidr: string;
  /** GKE subnet CIDR (e.g., 10.0.0.0/20) */
  gkeSubnetCidr: string;
  /** Pod IP range (secondary range for GKE pods) */
  podsCidr: string;
  /** Services IP range (secondary range for GKE services) */
  servicesCidr: string;
  /** Private services subnet for Cloud SQL, Redis, etc. */
  privateServicesCidr: string;
  /** Enable Cloud NAT for egress from private nodes */
  enableCloudNat: boolean;
}

// =============================================================================
// GKE Configuration
// =============================================================================

/** Configuration for a single GKE node pool */
export interface NodePoolConfig {
  /** Node pool name */
  name: string;
  /** Machine type (e.g., e2-standard-4) */
  machineType: string;
  /** Minimum number of nodes (autoscaler lower bound) */
  minNodes: number;
  /** Maximum number of nodes (autoscaler upper bound) */
  maxNodes: number;
  /** Initial number of nodes at creation */
  initialNodes: number;
  /** Disk size in GB */
  diskSizeGb: number;
  /** Disk type (pd-standard, pd-ssd, pd-balanced) */
  diskType: "pd-standard" | "pd-ssd" | "pd-balanced";
  /** Use spot/preemptible VMs for cost savings */
  spot: boolean;
  /** Node labels applied to all nodes in the pool */
  labels: Record<string, string>;
  /** Node taints for workload isolation */
  taints?: Array<{
    key: string;
    value: string;
    effect: "NO_SCHEDULE" | "PREFER_NO_SCHEDULE" | "NO_EXECUTE";
  }>;
  /** OAuth scopes granted to nodes */
  oauthScopes?: string[];
}

/** GKE cluster configuration */
export interface GkeConfig {
  /** GKE release channel for automatic upgrades */
  releaseChannel: GkeReleaseChannel;
  /** Kubernetes version (optional, uses release channel default if not set) */
  kubernetesVersion?: string;
  /** Enable GKE Autopilot mode (Google manages node pools) */
  enableAutopilot: boolean;
  /** Enable private cluster (no public IPs on nodes) */
  enablePrivateCluster: boolean;
  /** Enable private endpoint (control plane not accessible from internet) */
  enablePrivateEndpoint: boolean;
  /** Master authorized networks allowed to access the control plane */
  masterAuthorizedNetworks: Array<{
    displayName: string;
    cidrBlock: string;
  }>;
  /** Node pools configuration */
  nodePools: NodePoolConfig[];
  /** Enable Workload Identity for pod-level IAM */
  enableWorkloadIdentity: boolean;
  /** Enable Binary Authorization for image validation */
  enableBinaryAuthorization: boolean;
  /** Enable network policy enforcement (Calico) */
  enableNetworkPolicy: boolean;
  /** Enable Vertical Pod Autoscaling */
  enableVpa: boolean;
  /** Enable HTTP load balancing addon (GCE ingress) */
  enableHttpLoadBalancing: boolean;
  /** Enable Horizontal Pod Autoscaling */
  enableHpa: boolean;
  /** Maintenance window schedule (RFC 3339 format) */
  maintenanceWindow?: {
    startTime: string;
    endTime: string;
    recurrence: string;
  };
}

