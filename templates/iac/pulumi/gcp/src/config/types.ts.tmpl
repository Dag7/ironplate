  /** Cloud SQL edition: ENTERPRISE (standard) or ENTERPRISE_PLUS (advanced) */
  edition: "ENTERPRISE" | "ENTERPRISE_PLUS";
  /** Enable high availability (regional instance with failover replica) */
  highAvailability: boolean;
  /** Disk size in GB */
  diskSizeGb: number;
  /** Enable automatic disk size increase */
