/**
 * Authentication strategy for ArgoCD Image Updater to access container registries.
 *
 * - "workload-identity-script": Uses external script to fetch tokens from GKE metadata server.
 *   Best for: GKE with Workload Identity enabled + org policies blocking SA keys.
 *   Requires: GCP SA with artifactregistry.reader role + Workload Identity binding.
 *
 * - "workload-identity-native": Uses argocd-image-updater's native 'gcp' credential type.
 *   Best for: GCR (gcr.io) registries. May not work with Artifact Registry (pkg.dev).
 *   Requires: GCP SA with storage.objectViewer role + Workload Identity binding.
 *
 * - "pull-secret": Uses Docker pull secret synced via External Secrets from GCP Secret Manager.
 *   Best for: Environments where SA keys are allowed and External Secrets is deployed.
 *   Requires: GCP SA key stored in Secret Manager + ExternalSecret.
 */
export type ImageUpdaterAuthStrategy =
  | "workload-identity-script"
  | "workload-identity-native"
  | "pull-secret";

/** ArgoCD Image Updater configuration for automatic image promotion */
