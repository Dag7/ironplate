  registryPrefix: string;
  /** Image update strategy */
  updateStrategy: "semver" | "latest" | "digest";
  /** Git write-back method for recording image updates */
  writeBackMethod: "git" | "argocd";
  /** Branch for write-back commits (if using git method) */
  writeBackBranch?: string;
  /**
   * Authentication strategy for registry access.
   * @default "workload-identity-script"
   */
  authStrategy?: ImageUpdaterAuthStrategy;
}

