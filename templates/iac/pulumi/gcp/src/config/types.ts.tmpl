  /** PostgreSQL major version (e.g., "POSTGRES_16") */
  postgresVersion: string;
  /** Enable point-in-time recovery via WAL archiving */
  enablePointInTimeRecovery: boolean;
  /** Number of days to retain automated backups */
  backupRetentionDays: number;
  /** Prevent accidental instance deletion */
  deletionProtection: boolean;
  /** Database flags (key-value pairs applied to the instance) */
  databaseFlags?: Record<string, string>;
  /** Preferred maintenance window */
  maintenanceWindow?: {
    /** Day of week (1 = Monday, 7 = Sunday) */
