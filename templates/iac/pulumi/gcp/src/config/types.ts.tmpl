// =============================================================================
// Service Configuration
// =============================================================================

/** Resource requests and limits for a service container */
export interface ServiceResourceConfig {
  /** Resource requests (guaranteed allocation) */
  requests: { memory: string; cpu: string };
  /** Resource limits (maximum allowed) */
  limits: { memory: string; cpu: string };
}

/** Horizontal Pod Autoscaler configuration for a service */
export interface ServiceHpaConfig {
  /** Enable HPA for this service */
  enabled: boolean;
  /** Minimum number of replicas */
  minReplicas: number;
  /** Maximum number of replicas */
  maxReplicas: number;
  /** Target CPU utilization percentage (0-100) */
  targetCpuUtilization?: number;
  /** Target memory utilization percentage (0-100) */
  targetMemoryUtilization?: number;
  /** Custom metrics for scaling decisions */
  customMetrics?: Array<{
    name: string;
    targetValue: string;
    targetType: "Value" | "AverageValue" | "Utilization";
  }>;
  /** Stabilization window for scale-down decisions (seconds) */
  scaleDownStabilizationWindowSeconds?: number;
  /** Stabilization window for scale-up decisions (seconds) */
  scaleUpStabilizationWindowSeconds?: number;
}

/** Full configuration for a deployed service */
export interface ServiceConfig {
  /** Service name (used for deployment, service, and HPA naming) */
  name: string;
  /** Number of replicas (ignored if HPA is enabled) */
  replicas: number;
  /** Container resource configuration */
  resources: ServiceResourceConfig;
  /** Horizontal Pod Autoscaler configuration */
  hpa: ServiceHpaConfig;
  /** Node selector labels for pod placement */
  nodeSelector?: Record<string, string>;
  /** Tolerations for scheduling on tainted nodes */
  tolerations?: Array<{
    key: string;
    operator: "Exists" | "Equal";
    value?: string;
    effect: "NoSchedule" | "PreferNoSchedule" | "NoExecute";
  }>;
  /** Environment variables (non-secret, injected into container) */
  env?: Record<string, string>;
  /** Secret references mounted as environment variables */
  secretRefs?: string[];
  /** ConfigMap references mounted as environment variables */
  configMapRefs?: string[];
  /** Kubernetes Service type */
  serviceType: "ClusterIP" | "NodePort" | "LoadBalancer";
  /** Service port (external) */
  port: number;
  /** Target port (container port) */
  targetPort: number;
  /** Health check probe configuration */
  healthCheck: {
    /** HTTP path for readiness probe */
    readinessPath: string;
    /** HTTP path for liveness probe */
    livenessPath: string;
    /** Seconds to wait before starting probes */
    initialDelaySeconds: number;
    /** Seconds between probe checks */
    periodSeconds: number;
  };
}

