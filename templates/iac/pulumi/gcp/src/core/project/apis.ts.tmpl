/**
 * GCP API Enablement Module
 *
 * Enables all required GCP APIs for the {{ .Project.Metadata.Name }} platform.
 * APIs must be enabled before resources can be created.
 */

import * as gcp from "@pulumi/gcp";
import * as pulumi from "@pulumi/pulumi";
import { REQUIRED_GCP_APIS, type GcpApi } from "../../config/types.js";

// =============================================================================
// Types
// =============================================================================

export interface ApiEnablerArgs {
  /** GCP Project ID */
  project: string;
  /** Additional APIs to enable beyond the required set */
  additionalApis?: string[];
  /** Disable dependent services when disabling API */
  disableDependentServices?: boolean;
  /** Disable the API if it's no longer used */
  disableOnDestroy?: boolean;
}

export interface ApiEnablerOutputs {
  /** Map of API name to enabled service resource */
  enabledApis: Record<string, gcp.projects.Service>;
  /** List of all enabled API names */
  apiNames: pulumi.Output<string[]>;
}

// =============================================================================
// API Enabler Component
// =============================================================================

/**
 * Enables all required GCP APIs for the {{ .Project.Metadata.Name }} platform.
 *
 * This component should be created first, and other resources should
 * depend on it to ensure APIs are enabled before resource creation.
 */
export class ApiEnabler extends pulumi.ComponentResource {
  public readonly enabledApis: Record<string, gcp.projects.Service>;
  public readonly apiNames: pulumi.Output<string[]>;

  constructor(
    name: string,
    args: ApiEnablerArgs,
    opts?: pulumi.ComponentResourceOptions
  ) {
    super("{{ .Project.Metadata.Name }}:core:ApiEnabler", name, {}, opts);

    const {
      project,
      additionalApis = [],
      disableDependentServices = true,
      disableOnDestroy = false
    } = args;

    // Combine required and additional APIs
    const allApis = [...new Set([...REQUIRED_GCP_APIS, ...additionalApis])];

    // Enable each API
    this.enabledApis = {};
    const apiOutputs: pulumi.Output<string>[] = [];

    for (const api of allApis) {
      const apiName = api.replace(".googleapis.com", "").replace(/\./g, "-");

      const service = new gcp.projects.Service(
        `${name}-${apiName}`,
        {
          project: project,
          service: api,
          disableDependentServices: disableDependentServices,
          disableOnDestroy: disableOnDestroy
        },
        { parent: this }
      );

      this.enabledApis[api] = service;
      apiOutputs.push(service.service);
    }

    this.apiNames = pulumi.all(apiOutputs);

    this.registerOutputs({
      enabledApis: this.enabledApis,
      apiNames: this.apiNames
    });
  }

  /**
   * Get a specific API service resource
   */
  getApi(apiName: GcpApi): gcp.projects.Service | undefined {
    return this.enabledApis[apiName];
  }

  /**
   * Create dependency option for resources that need APIs enabled
   */
  dependsOn(): pulumi.Resource[] {
    return Object.values(this.enabledApis);
  }
}

// =============================================================================
// Factory Function
// =============================================================================

/**
 * Create API enabler with standard configuration
 */
export function createApiEnabler(
  project: string,
  opts?: pulumi.ComponentResourceOptions
): ApiEnabler {
  return new ApiEnabler("{{ .Project.Metadata.Name }}-apis", { project }, opts);
}
