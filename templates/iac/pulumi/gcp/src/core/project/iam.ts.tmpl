/**
 * IAM Configuration Module
 *
 * Sets up IAM roles, service accounts, and permissions for the
 * {{ .Project.Metadata.Name }} platform.
 * Follows the principle of least privilege.
 */

import * as gcp from "@pulumi/gcp";
import * as pulumi from "@pulumi/pulumi";
import type { EnvironmentConfig } from "../../config/types.js";
import { serviceAccountName, serviceAccountEmail } from "../../utils/naming.js";
import { gcpLabels } from "../../utils/tags.js";

// =============================================================================
// Types
// =============================================================================

export interface WorkloadIdentityConfig {
  /** Kubernetes namespace */
  namespace: string;
  /** Kubernetes service account name */
  serviceAccountName: string;
}

export interface ServiceAccountConfig {
  /** Service account name suffix */
  name: string;
  /** Display name */
  displayName: string;
  /** Description */
  description: string;
  /** IAM roles to grant */
  roles: string[];
  /** Whether to create a key for this SA */
  createKey?: boolean;
  /** Workload Identity binding configuration (optional) */
  workloadIdentity?: WorkloadIdentityConfig;
}

export interface IamSetupArgs {
  /** Environment configuration */
  config: EnvironmentConfig;
  /** Service accounts to create */
  serviceAccounts: ServiceAccountConfig[];
}

export interface IamSetupOutputs {
  /** Created service accounts */
  serviceAccounts: Record<string, gcp.serviceaccount.Account>;
  /** Service account emails */
  serviceAccountEmails: Record<string, pulumi.Output<string>>;
  /** Service account keys (if created) */
  serviceAccountKeys: Record<string, gcp.serviceaccount.Key>;
}

