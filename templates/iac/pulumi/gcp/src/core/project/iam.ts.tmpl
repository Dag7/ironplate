// =============================================================================
// IAM Setup Component
// =============================================================================

export class IamSetup extends pulumi.ComponentResource {
  public readonly serviceAccounts: Record<string, gcp.serviceaccount.Account>;
  public readonly serviceAccountEmails: Record<string, pulumi.Output<string>>;
  public readonly serviceAccountKeys: Record<string, gcp.serviceaccount.Key>;

  constructor(
    name: string,
    args: IamSetupArgs,
    opts?: pulumi.ComponentResourceOptions
  ) {
    super("{{ .Project.Metadata.Name }}:core:IamSetup", name, {}, opts);

    const { config, serviceAccounts } = args;
    const labels = gcpLabels(config, "iam");

    this.serviceAccounts = {};
    this.serviceAccountEmails = {};
    this.serviceAccountKeys = {};

    for (const saConfig of serviceAccounts) {
      const saName = serviceAccountName(config.envShortName, saConfig.name);
      const resourceName = `${name}-${saConfig.name}`;

      // Create service account
      const sa = new gcp.serviceaccount.Account(
        resourceName,
        {
          accountId: saName,
          displayName: saConfig.displayName,
          description: saConfig.description,
          project: config.gcpProject
        },
        { parent: this }
      );

      this.serviceAccounts[saConfig.name] = sa;
      this.serviceAccountEmails[saConfig.name] = sa.email;

      // Grant IAM roles
      for (let i = 0; i < saConfig.roles.length; i++) {
        const role = saConfig.roles[i];
        if (!role) continue;

        new gcp.projects.IAMMember(
          `${resourceName}-role-${i}`,
          {
            project: config.gcpProject,
            role: role,
            member: pulumi.interpolate`serviceAccount:${sa.email}`
          },
          { parent: this }
        );
      }

      // Create key if requested
      if (saConfig.createKey) {
        const key = new gcp.serviceaccount.Key(
          `${resourceName}-key`,
          {
            serviceAccountId: sa.name
          },
          { parent: this }
        );
        this.serviceAccountKeys[saConfig.name] = key;
      }
    }

    this.registerOutputs({
      serviceAccounts: this.serviceAccounts,
      serviceAccountEmails: this.serviceAccountEmails,
      serviceAccountKeys: this.serviceAccountKeys
    });
  }

  /**
   * Get a service account email by name
   */
  getServiceAccountEmail(name: string): pulumi.Output<string> | undefined {
    return this.serviceAccountEmails[name];
  }

  /**
   * Get all service accounts for GKE node configuration
   */
  getGkeNodeServiceAccount(): pulumi.Output<string> | undefined {
    return this.serviceAccountEmails["gke-nodes"];
  }
}

// =============================================================================
// Workload Identity Binding
// =============================================================================

export interface WorkloadIdentityBindingArgs {
  /** GCP project ID */
  project: string;
  /** GCP service account */
  gcpServiceAccount: gcp.serviceaccount.Account;
  /** Kubernetes namespace */
  namespace: string;
  /** Kubernetes service account name */
  k8sServiceAccount: string;
}

/**
 * Create a Workload Identity binding between a K8s SA and GCP SA
 */
export function createWorkloadIdentityBinding(
  name: string,
  args: WorkloadIdentityBindingArgs,
  opts?: pulumi.ResourceOptions
): gcp.serviceaccount.IAMMember {
  const { project, gcpServiceAccount, namespace, k8sServiceAccount } = args;

  return new gcp.serviceaccount.IAMMember(
    name,
    {
      serviceAccountId: gcpServiceAccount.name,
      role: "roles/iam.workloadIdentityUser",
      member: pulumi.interpolate`serviceAccount:${project}.svc.id.goog[${namespace}/${k8sServiceAccount}]`
    },
    opts
  );
}

// =============================================================================
// Factory Function
// =============================================================================

/**
 * Create IAM setup with default service accounts
 */
export function createIamSetup(
  config: EnvironmentConfig,
  additionalServiceAccounts: ServiceAccountConfig[] = [],
  opts?: pulumi.ComponentResourceOptions
): IamSetup {
  return new IamSetup(
    `{{ .Project.Metadata.Name }}-iam-${config.name}`,
    {
      config,
      serviceAccounts: [
        ...DEFAULT_SERVICE_ACCOUNTS,
        ...additionalServiceAccounts
      ]
    },
    opts
  );
}
