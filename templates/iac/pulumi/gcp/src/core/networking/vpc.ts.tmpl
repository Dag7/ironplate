import * as gcp from "@pulumi/gcp";
import * as pulumi from "@pulumi/pulumi";
import { projectId, region, stackName } from "../../config/loader";
import { NetworkConfig } from "../../config/types";

export interface NetworkOutputs {
  /** VPC network */
  network: gcp.compute.Network;
  /** Primary subnet */
  subnet: gcp.compute.Subnetwork;
  /** Cloud Router */
  router: gcp.compute.Router;
  /** Cloud NAT */
  nat: gcp.compute.RouterNat;
}

/**
 * Creates the VPC network, subnet with secondary ranges, Cloud NAT,
 * Cloud Router, and firewall rules for the {{ .Project.Metadata.Name }} project.
 */
export function createNetwork(
  networkConfig: NetworkConfig,
  dependsOn: pulumi.Resource[] = [],
): NetworkOutputs {
  // ── VPC Network ───────────────────────────────────────────────────
  const network = new gcp.compute.Network("vpc", {
    name: networkConfig.vpcName,
    project: projectId,
    autoCreateSubnetworks: false,
    routingMode: "REGIONAL",
  }, { dependsOn });

  // ── Subnet with secondary ranges for GKE ──────────────────────────
  const subnet = new gcp.compute.Subnetwork("subnet", {
    name: `{{ .Project.Metadata.Name }}-${stackName}-subnet`,
    project: projectId,
    region,
    network: network.id,
    ipCidrRange: networkConfig.subnetCidr,
    privateIpGoogleAccess: true,
    secondaryIpRanges: [
      {
        rangeName: "pods",
        ipCidrRange: networkConfig.podCidr,
      },
      {
        rangeName: "services",
        ipCidrRange: networkConfig.serviceCidr,
      },
    ],
  });

  // ── Cloud Router ──────────────────────────────────────────────────
  const router = new gcp.compute.Router("router", {
    name: `{{ .Project.Metadata.Name }}-${stackName}-router`,
    project: projectId,
    region,
    network: network.id,
  });

  // ── Cloud NAT ─────────────────────────────────────────────────────
  const nat = new gcp.compute.RouterNat("nat", {
    name: `{{ .Project.Metadata.Name }}-${stackName}-nat`,
    project: projectId,
    region,
    router: router.name,
    natIpAllocateOption: "AUTO_ONLY",
    sourceSubnetworkIpRangesToNat: "ALL_SUBNETWORKS_ALL_IP_RANGES",
    logConfig: {
      enable: true,
      filter: "ERRORS_ONLY",
    },
  });

  // ── Firewall: Allow internal communication ────────────────────────
  new gcp.compute.Firewall("allow-internal", {
    name: `{{ .Project.Metadata.Name }}-${stackName}-allow-internal`,
    project: projectId,
    network: network.id,
    direction: "INGRESS",
    priority: 1000,
    allows: [
      { protocol: "tcp", ports: ["0-65535"] },
      { protocol: "udp", ports: ["0-65535"] },
      { protocol: "icmp" },
    ],
    sourceRanges: [
      networkConfig.subnetCidr,
      networkConfig.podCidr,
      networkConfig.serviceCidr,
    ],
  });

  // ── Firewall: Allow health checks from GCP load balancers ─────────
  new gcp.compute.Firewall("allow-health-checks", {
    name: `{{ .Project.Metadata.Name }}-${stackName}-allow-health-checks`,
    project: projectId,
    network: network.id,
    direction: "INGRESS",
    priority: 1000,
    allows: [
      { protocol: "tcp" },
    ],
    sourceRanges: [
      "130.211.0.0/22",   // GCP health check range
      "35.191.0.0/16",    // GCP health check range
    ],
  });

  // ── Firewall: Allow SSH from Identity-Aware Proxy ─────────────────
  new gcp.compute.Firewall("allow-iap-ssh", {
    name: `{{ .Project.Metadata.Name }}-${stackName}-allow-iap-ssh`,
    project: projectId,
    network: network.id,
    direction: "INGRESS",
    priority: 1000,
    allows: [
      { protocol: "tcp", ports: ["22"] },
    ],
    sourceRanges: [
      "35.235.240.0/20",  // IAP forwarding range
    ],
  });

  return { network, subnet, router, nat };
}
