/**
 * VPC Configuration Module
 *
 * Creates the Virtual Private Cloud network for the {{ .Project.Metadata.Name }} platform.
 * Uses custom subnet mode for explicit control over IP addressing and
 * regional routing for optimal latency within a single region.
 */

import * as gcp from "@pulumi/gcp";
import * as pulumi from "@pulumi/pulumi";
import type { EnvironmentConfig } from "../../config/types.js";
import { resourceName } from "../../utils/naming.js";

// =============================================================================
// Types
// =============================================================================

/** Arguments for creating a VPC component */
export interface VpcArgs {
  /** Environment configuration */
  config: EnvironmentConfig;
}

/** Outputs exposed by the VPC component */
export interface VpcOutputs {
  /** VPC network resource */
  network: gcp.compute.Network;
  /** VPC network ID */
  networkId: pulumi.Output<string>;
  /** VPC network self link for cross-resource references */
  networkSelfLink: pulumi.Output<string>;
}

// =============================================================================
// VPC Component
// =============================================================================

/**
 * VPC ComponentResource for the {{ .Project.Metadata.Name }} platform.
 *
 * Creates a custom-mode VPC with regional routing. Subnets are managed
 * separately by the Subnets component, allowing independent lifecycle
 * management and fine-grained CIDR control.
 *
 * @example
 * ```ts
 * const vpc = createVpc(config);
 * // Use vpc.network for subnet and firewall references
 * ```
 */
export class Vpc extends pulumi.ComponentResource {
  public readonly network: gcp.compute.Network;
  public readonly networkId: pulumi.Output<string>;
  public readonly networkSelfLink: pulumi.Output<string>;

  constructor(
    name: string,
    args: VpcArgs,
    opts?: pulumi.ComponentResourceOptions
  ) {
    super("{{ .Project.Metadata.Name }}:networking:Vpc", name, {}, opts);

    const { config } = args;
    const vpcResourceName = resourceName("vpc", "network");

    // Create VPC network with custom subnet mode
    this.network = new gcp.compute.Network(
      name,
      {
        name: vpcResourceName,
        project: config.gcpProject,
        autoCreateSubnetworks: false, // Subnets managed by the Subnets component
        routingMode: "REGIONAL",
        deleteDefaultRoutesOnCreate: false,
        description: `{{ .Project.Metadata.Name }} ${config.name} environment VPC`,
      },
      { parent: this }
    );

    this.networkId = this.network.id;
    this.networkSelfLink = this.network.selfLink;

    this.registerOutputs({
      network: this.network,
      networkId: this.networkId,
      networkSelfLink: this.networkSelfLink,
    });
  }
}

// =============================================================================
// Factory Function
// =============================================================================

/**
 * Creates a VPC for the given environment.
 *
 * @param config - Environment configuration
 * @param opts - Pulumi component resource options
 * @returns A fully configured VPC component
 */
export function createVpc(
  config: EnvironmentConfig,
  opts?: pulumi.ComponentResourceOptions
): Vpc {
  return new Vpc(`{{ .Project.Metadata.Name }}-vpc-${config.name}`, { config }, opts);
}
