/**
 * Secret Value Generators
 *
 * Generates secure random values for various secret types.
 */

import * as pulumi from "@pulumi/pulumi";
import * as random from "@pulumi/random";
import * as tls from "@pulumi/tls";

// =============================================================================
// Types
// =============================================================================

export interface GeneratedSecret {
  name: string;
  value: pulumi.Output<string>;
  description: string;
}

// =============================================================================
// JWT Secret Generator
// =============================================================================

/**
 * Generate a secure JWT secret
 */
export function generateJwtSecret(
  name: string,
  opts?: pulumi.ResourceOptions
): GeneratedSecret {
  const secret = new random.RandomPassword(
    `${name}-jwt-secret`,
    {
      length: 64,
      special: false, // JWT secrets shouldn't have special chars
      upper: true,
      lower: true,
      numeric: true
    },
    opts
  );

  return {
    name: "JWT_SECRET",
    value: secret.result,
    description: "JWT signing secret for authentication tokens"
  };
}

// =============================================================================
// Encryption Key Generator
// =============================================================================

/**
 * Generate a secure encryption key
 */
export function generateEncryptionKey(
  name: string,
  opts?: pulumi.ResourceOptions
): GeneratedSecret {
  const secret = new random.RandomPassword(
    `${name}-encryption-key`,
    {
      length: 32,
      special: false,
      upper: true,
      lower: true,
      numeric: true
    },
    opts
  );

  return {
    name: "ENCRYPTION_KEY",
    value: secret.result,
    description: "AES-256 encryption key for secrets at rest"
  };
}

