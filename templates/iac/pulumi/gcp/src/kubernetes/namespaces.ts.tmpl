/**
 * Kubernetes namespaces for {{ .Project.Metadata.Name }}.
 *
 * Creates the application, infrastructure, and (optionally) monitoring
 * namespaces with appropriate labels for service mesh injection and
 * resource organization.
 */

import * as pulumi from "@pulumi/pulumi";
import * as k8s from "@pulumi/kubernetes";
import { toLabel } from "../utils/naming";

export interface NamespaceOutputs {
  /** Application namespace name */
  appNamespace: pulumi.Output<string>;
  /** Infrastructure namespace name */
  infraNamespace: pulumi.Output<string>;{{ if .Computed.HasObservability }}
  /** Monitoring namespace name */
  monitoringNamespace: pulumi.Output<string>;{{ end }}
}

export function createNamespaces(
  provider: k8s.Provider,
): NamespaceOutputs {
  const env = pulumi.getStack();

  const commonLabels: Record<string, string> = {
    "app.kubernetes.io/part-of": toLabel("{{ .Project.Metadata.Name }}"),
    "app.kubernetes.io/managed-by": "pulumi",
    environment: env,
    "istio-injection": "enabled",
  };

  // Application namespace - hosts all application workloads
  const appNs = new k8s.core.v1.Namespace(
    "{{ .Project.Metadata.Name }}",
    {
      metadata: {
        name: "{{ .Project.Metadata.Name }}",
        labels: {
          ...commonLabels,
          "kubernetes.io/metadata.name": "{{ .Project.Metadata.Name }}",
        },
      },
    },
    { provider },
  );

  // Infrastructure namespace - hosts shared infrastructure services
  const infraNs = new k8s.core.v1.Namespace(
    "{{ .Project.Metadata.Name }}-infra",
    {
      metadata: {
        name: "{{ .Project.Metadata.Name }}-infra",
        labels: {
          ...commonLabels,
          "kubernetes.io/metadata.name": "{{ .Project.Metadata.Name }}-infra",
          "istio-injection": "disabled",
        },
      },
    },
    { provider },
  );
{{ if .Computed.HasObservability }}
  // Monitoring namespace - hosts observability stack
  const monitoringNs = new k8s.core.v1.Namespace(
    "{{ .Project.Metadata.Name }}-monitoring",
    {
      metadata: {
        name: "{{ .Project.Metadata.Name }}-monitoring",
        labels: {
          ...commonLabels,
          "kubernetes.io/metadata.name": "{{ .Project.Metadata.Name }}-monitoring",
          "istio-injection": "disabled",
        },
      },
    },
    { provider },
  );
{{ end }}
  return {
    appNamespace: appNs.metadata.name,
    infraNamespace: infraNs.metadata.name,{{ if .Computed.HasObservability }}
    monitoringNamespace: monitoringNs.metadata.name,{{ end }}
  };
}
