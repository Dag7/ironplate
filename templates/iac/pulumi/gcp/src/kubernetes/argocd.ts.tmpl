{{ if .Computed.HasArgoCD }}/**
 * ArgoCD GitOps setup for {{ .Project.Metadata.Name }}.
 *
 * Installs ArgoCD and the ArgoCD Image Updater via Helm, configures
 * repository credentials, and creates the initial Application resource
 * to bootstrap continuous delivery.
 */

import * as pulumi from "@pulumi/pulumi";
import * as k8s from "@pulumi/kubernetes";
import { resourceName } from "../utils/naming";
import { envDomain } from "../utils/naming";

export interface ArgoCDOutputs {
  /** ArgoCD Helm release status */
  argocdStatus: pulumi.Output<string>;
  /** ArgoCD Image Updater Helm release status */
  imageUpdaterStatus: pulumi.Output<string>;
  /** ArgoCD server URL */
  serverUrl: pulumi.Output<string>;
}

export function setupArgoCD(
  provider: k8s.Provider,
  infraNamespace: pulumi.Output<string>,
  appNamespace: pulumi.Output<string>,
): ArgoCDOutputs {
  const config = new pulumi.Config();
  const env = pulumi.getStack();
  const baseDomain = "{{ .Project.Metadata.Domain }}";
  const domain = envDomain(env, baseDomain);
  const repoUrl = config.require("gitRepoUrl");
  const argocdNamespace = "argocd";

  // Create dedicated namespace for ArgoCD
  const argocdNs = new k8s.core.v1.Namespace(
    "argocd",
    {
      metadata: {
        name: argocdNamespace,
        labels: {
          "app.kubernetes.io/part-of": "{{ .Project.Metadata.Name }}",
          "app.kubernetes.io/managed-by": "pulumi",
        },
      },
    },
    { provider },
  );

  // Install ArgoCD via Helm
  const argocd = new k8s.helm.v3.Release(
    resourceName("helm", "argocd"),
    {
      chart: "argo-cd",
      version: "7.3.0",
      namespace: argocdNamespace,
      repositoryOpts: {
        repo: "https://argoproj.github.io/argo-helm",
      },
      values: {
        global: {
          domain: `argocd.${domain}`,
        },
        server: {
          extraArgs: ["--insecure"],
          ingress: {
            enabled: true,
            ingressClassName: "traefik",
            hosts: [`argocd.${domain}`],
            tls: [
              {
                secretName: "argocd-tls",
                hosts: [`argocd.${domain}`],
              },
            ],
          },
          resources: {
            requests: { cpu: "100m", memory: "256Mi" },
            limits: { cpu: "500m", memory: "512Mi" },
          },
        },
        controller: {
          resources: {
            requests: { cpu: "250m", memory: "512Mi" },
            limits: { cpu: "1000m", memory: "1Gi" },
          },
        },
        repoServer: {
          resources: {
            requests: { cpu: "100m", memory: "256Mi" },
            limits: { cpu: "500m", memory: "512Mi" },
          },
        },
        configs: {
          repositories: {
            "{{ .Project.Metadata.Name }}": {
              url: repoUrl,
              name: "{{ .Project.Metadata.Name }}",
              type: "git",
            },
          },
          params: {
            "server.enable.gzip": true,
            "application.namespaces": "{{ .Project.Metadata.Name }},{{ .Project.Metadata.Name }}-infra",
          },
        },
      },
    },
    { provider, dependsOn: [argocdNs] },
  );

  // Install ArgoCD Image Updater
  const imageUpdater = new k8s.helm.v3.Release(
    resourceName("helm", "argocd-image-updater"),
    {
      chart: "argocd-image-updater",
      version: "0.11.0",
      namespace: argocdNamespace,
      repositoryOpts: {
        repo: "https://argoproj.github.io/argo-helm",
      },
      values: {
        config: {
          argocd: {
            grpcWeb: true,
            serverAddress: "http://argocd-server.argocd.svc.cluster.local",
            insecure: true,
            plaintext: true,
          },
          registries: [
            {
              name: "{{ .Project.Metadata.Name }} Artifact Registry",
              api_url: `https://{{ .Project.Spec.Cloud.Region }}-docker.pkg.dev`,
              prefix: `{{ .Project.Spec.Cloud.Region }}-docker.pkg.dev`,
              credentials: "ext:/scripts/gcp-auth.sh",
              default: true,
            },
          ],
        },
        resources: {
          requests: { cpu: "50m", memory: "64Mi" },
          limits: { cpu: "200m", memory: "256Mi" },
        },
      },
    },
    { provider, dependsOn: [argocd] },
  );

  // ArgoCD Project for {{ .Project.Metadata.Name }}
  const argoProject = new k8s.apiextensions.CustomResource(
    resourceName("argocd", "project"),
    {
      apiVersion: "argoproj.io/v1alpha1",
      kind: "AppProject",
      metadata: {
        name: "{{ .Project.Metadata.Name }}",
        namespace: argocdNamespace,
        labels: {
          "app.kubernetes.io/part-of": "{{ .Project.Metadata.Name }}",
          "app.kubernetes.io/managed-by": "pulumi",
        },
      },
      spec: {
        description: "{{ .Project.Metadata.Name }} application project",
        sourceRepos: [repoUrl],
        destinations: [
          {
            server: "https://kubernetes.default.svc",
            namespace: appNamespace,
          },
          {
            server: "https://kubernetes.default.svc",
            namespace: infraNamespace,
          },
        ],
        clusterResourceWhitelist: [
          { group: "", kind: "Namespace" },
        ],
        namespaceResourceWhitelist: [
          { group: "*", kind: "*" },
        ],
      },
    },
    { provider, dependsOn: [argocd] },
  );

  // Initial Application for the project
  const app = new k8s.apiextensions.CustomResource(
    resourceName("argocd", "app"),
    {
      apiVersion: "argoproj.io/v1alpha1",
      kind: "Application",
      metadata: {
        name: "{{ .Project.Metadata.Name }}",
        namespace: argocdNamespace,
        labels: {
          "app.kubernetes.io/part-of": "{{ .Project.Metadata.Name }}",
          "app.kubernetes.io/managed-by": "pulumi",
        },
        annotations: {
          "argocd-image-updater.argoproj.io/write-back-method": "git",
        },
      },
      spec: {
        project: "{{ .Project.Metadata.Name }}",
        source: {
          repoURL: repoUrl,
          targetRevision: "HEAD",
          path: "helm/{{ .Project.Metadata.Name }}",
        },
        destination: {
          server: "https://kubernetes.default.svc",
          namespace: appNamespace,
        },
        syncPolicy: {
          automated: {
            prune: true,
            selfHeal: true,
          },
          syncOptions: [
            "CreateNamespace=false",
            "PruneLast=true",
          ],
          retry: {
            limit: 3,
            backoff: {
              duration: "5s",
              factor: 2,
              maxDuration: "3m",
            },
          },
        },
      },
    },
    { provider, dependsOn: [argoProject] },
  );

  return {
    argocdStatus: argocd.status,
    imageUpdaterStatus: imageUpdater.status,
    serverUrl: pulumi.output(`https://argocd.${domain}`),
  };
}
{{ end }}
