{{ if .Computed.HasExternalSecrets }}/**
 * External Secrets Operator setup for {{ .Project.Metadata.Name }}.
 *
 * Installs the External Secrets Operator via Helm, configures a
 * ClusterSecretStore backed by GCP Secret Manager, and creates
 * initial ExternalSecret resources for database credentials.
 */

import * as pulumi from "@pulumi/pulumi";
import * as k8s from "@pulumi/kubernetes";
import { resourceName } from "../utils/naming";

export interface SecretsOutputs {
  /** External Secrets Operator Helm release status */
  operatorStatus: pulumi.Output<string>;
  /** ClusterSecretStore name */
  secretStoreName: pulumi.Output<string>;
}

export function setupSecrets(
  provider: k8s.Provider,
  infraNamespace: pulumi.Output<string>,
  appNamespace: pulumi.Output<string>,
): SecretsOutputs {
  const config = new pulumi.Config();
  const gcpProject = config.require("gcpProject");

  // Install External Secrets Operator via Helm
  const esoRelease = new k8s.helm.v3.Release(
    resourceName("helm", "external-secrets"),
    {
      chart: "external-secrets",
      version: "0.10.0",
      namespace: infraNamespace,
      repositoryOpts: {
        repo: "https://charts.external-secrets.io",
      },
      values: {
        installCRDs: true,
        serviceAccount: {
          create: true,
          name: "external-secrets-sa",
          annotations: {
            "iam.gke.io/gcp-service-account": `external-secrets@${gcpProject}.iam.gserviceaccount.com`,
          },
        },
        webhook: {
          port: 9443,
        },
        resources: {
          requests: { cpu: "50m", memory: "128Mi" },
          limits: { cpu: "200m", memory: "256Mi" },
        },
      },
    },
    { provider },
  );

  // ClusterSecretStore pointing to GCP Secret Manager
  const secretStore = new k8s.apiextensions.CustomResource(
    resourceName("eso", "cluster-store"),
    {
      apiVersion: "external-secrets.io/v1beta1",
      kind: "ClusterSecretStore",
      metadata: {
        name: "{{ .Project.Metadata.Name }}-gcp-secret-manager",
        labels: {
          "app.kubernetes.io/part-of": "{{ .Project.Metadata.Name }}",
          "app.kubernetes.io/managed-by": "pulumi",
        },
      },
      spec: {
        provider: {
          gcpsm: {
            projectID: gcpProject,
          },
        },
      },
    },
    { provider, dependsOn: [esoRelease] },
  );

  // ExternalSecret for database credentials
  const dbSecret = new k8s.apiextensions.CustomResource(
    resourceName("eso", "db-credentials"),
    {
      apiVersion: "external-secrets.io/v1beta1",
      kind: "ExternalSecret",
      metadata: {
        name: "{{ .Project.Metadata.Name }}-db-credentials",
        namespace: appNamespace,
        labels: {
          "app.kubernetes.io/part-of": "{{ .Project.Metadata.Name }}",
          "app.kubernetes.io/managed-by": "pulumi",
        },
      },
      spec: {
        refreshInterval: "1h",
        secretStoreRef: {
          name: "{{ .Project.Metadata.Name }}-gcp-secret-manager",
          kind: "ClusterSecretStore",
        },
        target: {
          name: "{{ .Project.Metadata.Name }}-db-credentials",
          creationPolicy: "Owner",
        },
        data: [
          {
            secretKey: "DATABASE_URL",
            remoteRef: {
              key: "{{ .Project.Metadata.Name }}-database-url",
            },
          },
          {
            secretKey: "DATABASE_PASSWORD",
            remoteRef: {
              key: "{{ .Project.Metadata.Name }}-database-password",
            },
          },
          {
            secretKey: "DATABASE_USERNAME",
            remoteRef: {
              key: "{{ .Project.Metadata.Name }}-database-username",
            },
          },
        ],
      },
    },
    { provider, dependsOn: [secretStore] },
  );

  return {
    operatorStatus: esoRelease.status,
    secretStoreName: secretStore.metadata.name,
  };
}
{{ end }}
