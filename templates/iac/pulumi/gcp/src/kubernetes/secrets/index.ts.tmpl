/**
 * Kubernetes Secrets Infrastructure Module
 *
 * Deploys External Secrets Operator and ClusterSecretStore.
 *
 * NOTE: This module only deploys the INFRASTRUCTURE for secrets synchronization.
 * The actual ExternalSecret CRDs are part of the application layer and are
 * defined in the Kustomize overlays (k8s/deployment/app/{staging,production}/secrets/).
 */

import * as gcp from "@pulumi/gcp";
import * as k8s from "@pulumi/kubernetes";
import * as pulumi from "@pulumi/pulumi";
import type { EnvironmentConfig } from "../../config/types.js";
import { createWorkloadIdentityBinding } from "../../core/project/iam.js";
import { ExternalSecrets, createExternalSecrets } from "./external-secrets.js";

// Re-export components
export * from "./external-secrets.js";

// =============================================================================
// Types
// =============================================================================

export interface SecretsInfraArgs {
  /** Environment configuration */
  config: EnvironmentConfig;
  /** Kubernetes provider */
  k8sProvider: k8s.Provider;
  /** External Secrets namespace */
  externalSecretsNamespace: k8s.core.v1.Namespace;
  /** GCP service account for External Secrets */
  gcpServiceAccount: gcp.serviceaccount.Account;
}

// =============================================================================
// Secrets Infrastructure Component
// =============================================================================

/**
 * Deploys External Secrets Operator and ClusterSecretStore.
 *
 * This provides the infrastructure for syncing secrets from GCP Secret Manager
 * to Kubernetes. The actual ExternalSecret resources are deployed by Kustomize
 * as part of the application layer.
 */
export class SecretsInfra extends pulumi.ComponentResource {
  public readonly externalSecrets: ExternalSecrets;
  public readonly workloadIdentityBinding: gcp.serviceaccount.IAMMember;

  constructor(
    name: string,
    args: SecretsInfraArgs,
    opts?: pulumi.ComponentResourceOptions
  ) {
    super("{{ .Project.Metadata.Name }}:kubernetes:SecretsInfra", name, {}, opts);

    const { config, k8sProvider, externalSecretsNamespace, gcpServiceAccount } =
      args;

    // =========================================================================
    // Workload Identity Binding
    // =========================================================================
    // This allows the K8s ServiceAccount to impersonate the GCP ServiceAccount
    // to access GCP Secret Manager via Workload Identity.
    this.workloadIdentityBinding = createWorkloadIdentityBinding(
      `${name}-wi-binding`,
      {
        project: config.gcpProject,
        gcpServiceAccount: gcpServiceAccount,
        namespace: "external-secrets",
        k8sServiceAccount: "external-secrets"
      },
      { parent: this }
    );

    // =========================================================================
    // Deploy External Secrets Operator + ClusterSecretStore
    // =========================================================================
    this.externalSecrets = createExternalSecrets(
      config,
      k8sProvider,
      externalSecretsNamespace,
      gcpServiceAccount.email,
      { parent: this, dependsOn: [this.workloadIdentityBinding] }
    );

    // NOTE: ExternalSecret CRDs are NOT created here.
    // They are defined in the Kustomize overlays and deployed by Tilt/ArgoCD.
    // See: k8s/deployment/app/{staging,production}/external-secrets/

    this.registerOutputs({
      externalSecrets: this.externalSecrets,
      workloadIdentityBinding: this.workloadIdentityBinding
    });
  }
}

// =============================================================================
// Factory Function
// =============================================================================

export function createSecretsInfra(
  config: EnvironmentConfig,
  k8sProvider: k8s.Provider,
  externalSecretsNamespace: k8s.core.v1.Namespace,
  gcpServiceAccount: gcp.serviceaccount.Account,
  opts?: pulumi.ComponentResourceOptions
): SecretsInfra {
  return new SecretsInfra(
    `{{ .Project.Metadata.Name }}-secrets-infra-${config.name}`,
    { config, k8sProvider, externalSecretsNamespace, gcpServiceAccount },
    opts
  );
}

// Keep backward compatibility alias
export {
  SecretsInfra as SecretsStack,
  createSecretsInfra as createSecretsStack
};
