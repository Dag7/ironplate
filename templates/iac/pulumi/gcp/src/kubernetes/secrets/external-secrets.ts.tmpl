/**
 * External Secrets Operator Module
 *
 * Deploys External Secrets Operator and configures ClusterSecretStore
 * to sync secrets from GCP Secret Manager.
 */

import * as k8s from "@pulumi/kubernetes";
import * as pulumi from "@pulumi/pulumi";
import type { EnvironmentConfig } from "../../config/types.js";
import { k8sLabels } from "../../utils/tags.js";

// =============================================================================
// Types
// =============================================================================

export interface ExternalSecretsArgs {
  /** Environment configuration */
  config: EnvironmentConfig;
  /** Kubernetes provider */
  k8sProvider: k8s.Provider;
  /** Namespace for External Secrets Operator */
  namespace: k8s.core.v1.Namespace;
  /** GCP service account email for Workload Identity */
  gcpServiceAccountEmail: pulumi.Output<string>;
}

export interface ExternalSecretsOutputs {
  /** External Secrets Operator Helm release */
  helmRelease: k8s.helm.v3.Release;
  /** ClusterSecretStore for GCP */
  secretStore: k8s.apiextensions.CustomResource;
}

// =============================================================================
// External Secrets Component
// =============================================================================

export class ExternalSecrets extends pulumi.ComponentResource {
  public readonly helmRelease: k8s.helm.v3.Release;
  public readonly secretStore: k8s.apiextensions.CustomResource;

  constructor(
    name: string,
    args: ExternalSecretsArgs,
    opts?: pulumi.ComponentResourceOptions
  ) {
    super("{{ .Project.Metadata.Name }}:kubernetes:ExternalSecrets", name, {}, opts);

    const { config, k8sProvider, namespace, gcpServiceAccountEmail } = args;
    const labels = k8sLabels(config, "external-secrets");

    // ==========================================================================
    // Deploy External Secrets Operator via Helm
    // ==========================================================================
    this.helmRelease = new k8s.helm.v3.Release(
      `${name}-operator`,
      {
        name: "external-secrets",
        namespace: namespace.metadata.name,
        chart: "external-secrets",
        repositoryOpts: {
          repo: "https://charts.external-secrets.io"
        },
        version: "0.9.11",
        values: {
          installCRDs: true,
          serviceAccount: {
            create: true,
            name: "external-secrets",
            annotations: {
              "iam.gke.io/gcp-service-account": gcpServiceAccountEmail
            }
          },
          webhook: {
            create: true
          },
          certController: {
            create: true
          },
          resources: {
            requests: {
              cpu: "50m",
              memory: "128Mi"
            },
            limits: {
              cpu: "200m",
              memory: "256Mi"
            }
          },
          // Node selector - ESO runs on infra nodes (stable, non-spot)
          nodeSelector: {
            "workload-type": "infra"
          },
          // Tolerations for infra node pool
          tolerations: [
            {
              key: "workload-type",
              operator: "Equal",
              value: "infra",
              effect: "NoSchedule"
            }
          ]
        }
      },
      { parent: this, provider: k8sProvider }
    );

    // ==========================================================================
    // Create ClusterSecretStore for GCP Secret Manager
    // ==========================================================================
    this.secretStore = new k8s.apiextensions.CustomResource(
      `${name}-secret-store`,
      {
        apiVersion: "external-secrets.io/v1beta1",
        kind: "ClusterSecretStore",
        metadata: {
          name: config.secrets.clusterSecretStoreName,
          labels: labels
        },
        spec: {
          provider: {
            gcpsm: {
              projectID: config.gcpProject,
              auth: {
                workloadIdentity: {
                  clusterLocation: config.gcpRegion,
                  clusterName: `{{ .Project.Metadata.Name }}-${config.name}-cluster`,
                  clusterProjectID: config.gcpProject,
                  serviceAccountRef: {
                    name: "external-secrets",
                    namespace: "external-secrets"
                  }
                }
              }
            }
          }
        }
      },
      {
        parent: this,
        provider: k8sProvider,
        dependsOn: [this.helmRelease]
      }
    );

    this.registerOutputs({
      helmRelease: this.helmRelease,
      secretStore: this.secretStore
    });
  }
}

// =============================================================================
// External Secret CRD Generator
// =============================================================================

export interface ExternalSecretDefinition {
  /** Secret name in Kubernetes */
  name: string;
  /** Namespace for the secret */
  namespace: string;
  /** Secret keys to fetch from GCP Secret Manager */
  keys: Array<{
    /** Key name in Kubernetes secret */
    secretKey: string;
    /** Secret name in GCP Secret Manager */
    remoteRef: string;
  }>;
  /** Refresh interval */
  refreshInterval?: string;
}

/**
 * Create an ExternalSecret Custom Resource
 */
export function createExternalSecret(
  name: string,
  definition: ExternalSecretDefinition,
  clusterSecretStoreName: string,
  k8sProvider: k8s.Provider,
  opts?: pulumi.ResourceOptions
): k8s.apiextensions.CustomResource {
  return new k8s.apiextensions.CustomResource(
    name,
    {
      apiVersion: "external-secrets.io/v1beta1",
      kind: "ExternalSecret",
      metadata: {
        name: definition.name,
        namespace: definition.namespace
      },
      spec: {
        refreshInterval: definition.refreshInterval ?? "1h",
        secretStoreRef: {
          name: clusterSecretStoreName,
          kind: "ClusterSecretStore"
        },
        target: {
          name: definition.name,
          creationPolicy: "Owner"
        },
        data: definition.keys.map((key) => ({
          secretKey: key.secretKey,
          remoteRef: {
            key: key.remoteRef
          }
        }))
      }
    },
    { provider: k8sProvider, ...opts }
  );
}

// =============================================================================
// Factory Function
// =============================================================================

export function createExternalSecrets(
  config: EnvironmentConfig,
  k8sProvider: k8s.Provider,
  namespace: k8s.core.v1.Namespace,
  gcpServiceAccountEmail: pulumi.Output<string>,
  opts?: pulumi.ComponentResourceOptions
): ExternalSecrets {
  return new ExternalSecrets(
    `{{ .Project.Metadata.Name }}-external-secrets-${config.name}`,
    { config, k8sProvider, namespace, gcpServiceAccountEmail },
    opts
  );
}
