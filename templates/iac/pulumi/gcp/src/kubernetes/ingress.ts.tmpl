/**
 * Traefik ingress controller for {{ .Project.Metadata.Name }}.
 *
 * Installs Traefik via Helm chart with a LoadBalancer service bound
 * to the provisioned static IP, TLS termination through cert-manager,
 * and security-focused default headers.
 */

import * as pulumi from "@pulumi/pulumi";
import * as k8s from "@pulumi/kubernetes";
import { resourceName } from "../utils/naming";
import { envDomain } from "../utils/naming";
import { InfraOutputs } from "../config/types";

export interface IngressOutputs {
  /** Traefik Helm release status */
  traefikStatus: pulumi.Output<string>;
  /** LoadBalancer external IP */
  loadBalancerIp: pulumi.Output<string>;
}

export function setupIngress(
  provider: k8s.Provider,
  infra: InfraOutputs,
  infraNamespace: pulumi.Output<string>,
): IngressOutputs {
  const config = new pulumi.Config();
  const env = pulumi.getStack();
  const baseDomain = "{{ .Project.Metadata.Domain }}";
  const domain = envDomain(env, baseDomain);
  const isDev = env === "dev" || env === "development";

  // Install Traefik via Helm
  const traefik = new k8s.helm.v3.Release(
    resourceName("helm", "traefik"),
    {
      chart: "traefik",
      version: "28.0.0",
      namespace: infraNamespace,
      repositoryOpts: {
        repo: "https://traefik.github.io/charts",
      },
      values: {
        deployment: {
          replicas: isDev ? 1 : 2,
        },
        service: {
          type: "LoadBalancer",
          annotations: {
            "cloud.google.com/load-balancer-type": "External",
          },
          spec: {
            loadBalancerIP: infra.staticIpAddress,
          },
        },
        ingressRoute: {
          dashboard: {
            enabled: isDev,
            matchRule: `Host(\`traefik.${domain}\`)`,
            entryPoints: ["websecure"],
          },
        },
        ports: {
          web: {
            port: 8000,
            exposedPort: 80,
            redirectTo: { port: "websecure" },
          },
          websecure: {
            port: 8443,
            exposedPort: 443,
            tls: {
              enabled: true,
            },
          },
        },
        tlsStore: {
          default: {
            defaultCertificate: {
              secretName: `${resourceName("tls", "default")}`,
            },
          },
        },
        additionalArguments: [
          "--entrypoints.websecure.http.tls.certresolver=letsencrypt",
          "--certificatesresolvers.letsencrypt.acme.email=admin@{{ .Project.Metadata.Domain }}",
          "--certificatesresolvers.letsencrypt.acme.storage=/data/acme.json",
          "--certificatesresolvers.letsencrypt.acme.tlschallenge=true",
        ],
        resources: {
          requests: { cpu: "100m", memory: "128Mi" },
          limits: { cpu: "500m", memory: "512Mi" },
        },
        logs: {
          general: { level: isDev ? "DEBUG" : "INFO" },
          access: { enabled: true },
        },
      },
    },
    { provider },
  );

  // Default security headers middleware
  const securityHeaders = new k8s.apiextensions.CustomResource(
    resourceName("traefik", "security-headers"),
    {
      apiVersion: "traefik.io/v1alpha1",
      kind: "Middleware",
      metadata: {
        name: "security-headers",
        namespace: infraNamespace,
        labels: {
          "app.kubernetes.io/part-of": "{{ .Project.Metadata.Name }}",
          "app.kubernetes.io/managed-by": "pulumi",
        },
      },
      spec: {
        headers: {
          frameDeny: true,
          contentTypeNosniff: true,
          browserXssFilter: true,
          referrerPolicy: "strict-origin-when-cross-origin",
          stsSeconds: 31536000,
          stsIncludeSubdomains: true,
          stsPreload: true,
          customResponseHeaders: {
            "X-Powered-By": "",
            Server: "",
          },
        },
      },
    },
    { provider, dependsOn: [traefik] },
  );

  // Rate limiting middleware
  const rateLimiting = new k8s.apiextensions.CustomResource(
    resourceName("traefik", "rate-limit"),
    {
      apiVersion: "traefik.io/v1alpha1",
      kind: "Middleware",
      metadata: {
        name: "rate-limit",
        namespace: infraNamespace,
        labels: {
          "app.kubernetes.io/part-of": "{{ .Project.Metadata.Name }}",
          "app.kubernetes.io/managed-by": "pulumi",
        },
      },
      spec: {
        rateLimit: {
          average: 100,
          burst: 200,
          period: "1m",
        },
      },
    },
    { provider, dependsOn: [traefik] },
  );

  return {
    traefikStatus: traefik.status,
    loadBalancerIp: pulumi.output(infra.staticIpAddress),
  };
}
