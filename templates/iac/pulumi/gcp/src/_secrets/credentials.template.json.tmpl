{{ $hasHasura := .Computed.HasHasura -}}
{{ $hasLangfuse := .Computed.HasLangfuse -}}
{{ $hasArgoCD := .Computed.HasArgoCD -}}
{{ $hasObservability := .Computed.HasObservability -}}
{
  "jwt-credentials": {
    "jwt-secret": "REPLACE_WITH_BASE64_SECRET",
    "jwt-issuer": "{{ .Project.Metadata.Name }}",
    "jwt-audience": "{{ .Project.Metadata.Name }}-api"
  },
  "encryption-credentials": {
    "encryption-key": "REPLACE_WITH_BASE64_SECRET"
  },
{{- if $hasHasura }}
  "hasura-credentials": {
    "hasura-admin-secret": "REPLACE_WITH_SECRET",
    "hasura-graphql-jwt-secret": "{\"type\":\"HS256\",\"key\":\"SAME_AS_JWT_SECRET\",\"claims_namespace\":\"https://hasura.io/jwt/claims\"}",
    "hasura-webhook-secret": "REPLACE_WITH_WEBHOOK_SECRET"
  },
{{- end }}
  "oauth-credentials": {
    "google-client-id": "REPLACE_WITH_CLIENT_ID.apps.googleusercontent.com",
    "google-client-secret": "REPLACE_WITH_CLIENT_SECRET",
    "google-authorization-url": "https://accounts.google.com/o/oauth2/v2/auth",
    "google-token-url": "https://oauth2.googleapis.com/token",
    "google-user-url": "https://www.googleapis.com/oauth2/v3/userinfo",
    "github-client-id": "",
    "github-client-secret": ""
  },
  "llm-credentials": {
    "openai-api-key": "REPLACE_WITH_OPENAI_KEY",
    "anthropic-api-key": "",
    "google-api-key": "",
    "ollama-base-url": "http://host.docker.internal:11434"
  },
{{- if $hasLangfuse }}
  "langfuse-credentials": {
    "langfuse-nextauth-secret": "REPLACE_WITH_BASE64_SECRET",
    "langfuse-salt": "REPLACE_WITH_BASE64_SECRET",
    "langfuse-encryption-key": "REPLACE_WITH_64_HEX_CHARS",
    "langfuse-public-key": "pk-lf-REPLACE",
    "langfuse-secret-key": "sk-lf-REPLACE",
    "langfuse-base-url": "http://langfuse.{{ .Project.Metadata.Name }}.svc.cluster.local",
    "langfuse-init-user-password": "REPLACE_WITH_PASSWORD"
  },
{{- end }}
{{- if $hasObservability }}
  "statsig-credentials": {
    "server-key": "REPLACE_WITH_STATSIG_SERVER_KEY"
  },
{{- end }}
  "email-credentials": {
    "resend-api-key": "REPLACE_WITH_RESEND_API_KEY"
  },
{{- if $hasArgoCD }}
  "github-app-credentials": {
    "app-id": "REPLACE_WITH_APP_ID",
    "installation-id": "REPLACE_WITH_INSTALLATION_ID",
    "private-key": "REPLACE_WITH_PRIVATE_KEY_PEM",
    "client-id": "",
    "client-secret": ""
  },
  "slack-credentials": {
    "slack-bot-token": "xoxb-REPLACE_WITH_BOT_TOKEN"
  },
{{- end }}
  "visitor-credentials": {
    "cookie-secret": "REPLACE_WITH_32_PLUS_CHAR_SECRET"
  },
  "search-provider-credentials": {
    "brave-search-api-key": "REPLACE_WITH_BRAVE_SEARCH_API_KEY"
  }
}
