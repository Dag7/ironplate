{{- if .Computed.HasLangfuse }}
| `langfuse-credentials`   | LLM observability platform                  |
{{- end }}
{{- if .Computed.HasObservability }}
| `statsig-credentials`    | Feature flags (Statsig)                     |
{{- end }}
| `email-credentials`      | Email service (Resend)                      |
{{- if .Computed.HasArgoCD }}
| `github-app-credentials` | GitHub App for ArgoCD repo access           |
| `slack-credentials`      | Slack Bot Token for ArgoCD notifications    |
