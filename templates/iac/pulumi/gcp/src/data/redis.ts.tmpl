{{ if .Computed.HasRedis }}/**
 * Memorystore Redis instance for {{ .Project.Metadata.Name }}.
 *
 * Provisions a managed Redis instance with private networking and
 * AUTH enabled for secure in-cluster access.
 */

import * as pulumi from "@pulumi/pulumi";
import * as gcp from "@pulumi/gcp";
import { defaultLabels } from "../utils/tags";
import { resourceName } from "../utils/naming";
import { InfraOutputs } from "../config/types";

export interface RedisOutputs {
  /** Redis instance host (private IP) */
  host: pulumi.Output<string>;
  /** Redis instance port */
  port: pulumi.Output<number>;
  /** Redis AUTH string */
  authString: pulumi.Output<string>;
  /** Full Redis connection URI */
  connectionUri: pulumi.Output<string>;
}

export function createRedis(infra: InfraOutputs): RedisOutputs {
  const config = new pulumi.Config();
  const project = config.require("gcpProject");
  const region = config.get("gcpRegion") || "{{ .Project.Spec.Cloud.Region }}";
  const memorySizeGb = config.getNumber("redisMemorySizeGb") || 1;
  const redisVersion = config.get("redisVersion") || "REDIS_7_0";
  const labels = defaultLabels();

  const redis = new gcp.redis.Instance(resourceName("redis", "instance"), {
    project,
    region,
    displayName: `${resourceName("redis", "instance")} - {{ .Project.Metadata.Name }}`,
    tier: "STANDARD_HA",
    memorySizeGb,
    redisVersion,
    authEnabled: true,
    transitEncryptionMode: "SERVER_AUTHENTICATION",
    authorizedNetwork: infra.networkSelfLink,
    connectMode: "PRIVATE_SERVICE_ACCESS",
    redisConfigs: {
      "maxmemory-policy": "allkeys-lru",
      "notify-keyspace-events": "",
    },
    maintenancePolicy: {
      weeklyMaintenanceWindows: [
        {
          day: "SUNDAY",
          startTime: {
            hours: 4,
            minutes: 0,
            seconds: 0,
            nanos: 0,
          },
        },
      ],
    },
    labels,
  });

  const connectionUri = pulumi.interpolate`redis://:${redis.authString}@${redis.host}:${redis.port}`;

  return {
    host: redis.host,
    port: redis.port,
    authString: redis.authString,
    connectionUri,
  };
}
{{ end }}
