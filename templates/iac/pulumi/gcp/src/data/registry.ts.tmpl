/**
 * Artifact Registry Docker repository for {{ .Project.Metadata.Name }}.
 *
 * Creates a Docker-format Artifact Registry repository and configures
 * IAM bindings so GKE nodes can pull images and the CI/CD service
 * account can push images.
 */

import * as pulumi from "@pulumi/pulumi";
import * as gcp from "@pulumi/gcp";
import { defaultLabels } from "../utils/tags";
import { resourceName } from "../utils/naming";
import { InfraOutputs } from "../config/types";

export interface RegistryOutputs {
  /** Artifact Registry repository ID */
  repositoryId: pulumi.Output<string>;
  /** Full registry URL for docker push/pull */
  registryUrl: pulumi.Output<string>;
}

export function createRegistry(infra: InfraOutputs): RegistryOutputs {
  const config = new pulumi.Config();
  const project = config.require("gcpProject");
  const region = config.get("gcpRegion") || "{{ .Project.Spec.Cloud.Region }}";
  const labels = defaultLabels();

  const repository = new gcp.artifactregistry.Repository(
    resourceName("ar", "docker"),
    {
      project,
      location: region,
      repositoryId: "{{ .Project.Metadata.Name }}",
      format: "DOCKER",
      description: `Docker images for {{ .Project.Metadata.Name }}`,
      labels,
      cleanupPolicies: [
        {
          id: "keep-recent",
          action: "KEEP",
          mostRecentVersions: {
            keepCount: 10,
          },
        },
        {
          id: "delete-untagged",
          action: "DELETE",
          condition: {
            tagState: "UNTAGGED",
            olderThan: "604800s", // 7 days
          },
        },
      ],
    },
  );

  // Allow GKE nodes to pull images from the registry
  const nodeReaderBinding =
    new gcp.artifactregistry.RepositoryIamMember(
      resourceName("ar", "node-reader"),
      {
        project,
        location: region,
        repository: repository.repositoryId,
        role: "roles/artifactregistry.reader",
        member: pulumi.interpolate`serviceAccount:${infra.nodeServiceAccountEmail}`,
      },
    );

  // Allow CI/CD service account to push images to the registry
  const cicdWriterBinding =
    new gcp.artifactregistry.RepositoryIamMember(
      resourceName("ar", "cicd-writer"),
      {
        project,
        location: region,
        repository: repository.repositoryId,
        role: "roles/artifactregistry.writer",
        member: pulumi.interpolate`serviceAccount:${infra.cicdServiceAccountEmail}`,
      },
    );

  const registryUrl = pulumi.interpolate`${region}-docker.pkg.dev/${project}/${repository.repositoryId}`;

  return {
    repositoryId: repository.repositoryId,
    registryUrl,
  };
}
