# =============================================================================
# {{ .Computed.NamePascal }} Platform - Tiltfile
# =============================================================================
# Local development environment using Helm charts
# Generated by ironplate
# =============================================================================
{{ if .Computed.HasNode }}
# Load custom Tilt utilities
load('./utils/tilt/node.tilt', 'node_service', 'client_node_service')
{{ end }}
{{ if .Computed.HasGo }}
load('./utils/tilt/go.utils.tilt', 'go_service')
{{ end }}
load('./utils/tilt/dev.utils.tilt', 'get_dev_tool_deps'{{ if .Computed.HasGo }}, 'get_go_dev_tool_deps'{{ end }})

# Configure Tilt settings
docker_prune_settings(max_age_mins=60, num_builds=2, keep_recent=1)
update_settings(max_parallel_updates=3, k8s_upsert_timeout_secs=60)

# Allow Tilt to use k3d context
allow_k8s_contexts('k3d-{{ .Project.Metadata.Name }}')

target = "development"

# ==============================================================================
# IRONPLATE:SERVICES:START
# ==============================================================================
# Services will be added here by 'iron generate service'
# ==============================================================================
# IRONPLATE:SERVICES:END

# ==============================================================================
# Infrastructure
# ==============================================================================
{{ if hasItem .Project.Spec.Infrastructure.Components "kafka" }}
# Kafka (Strimzi + KRaft)
load('./k8s/helm/infra/kafka/Tiltfile', 'setup_kafka')
setup_kafka("development")
{{ end }}
{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }}
# Hasura GraphQL Engine
load('./k8s/helm/infra/hasura/Tiltfile', 'setup_hasura')
setup_hasura("development")
{{ end }}
{{ if hasItem .Project.Spec.Infrastructure.Components "dapr" }}
# Dapr Runtime
load('./k8s/helm/infra/dapr/Tiltfile', 'setup_dapr')
setup_dapr("development")
{{ end }}
{{ if hasItem .Project.Spec.Infrastructure.Components "observability" }}
# Observability Stack (OTEL + Tempo + Prometheus/Grafana)
load('./k8s/helm/infra/observability-stack/Tiltfile', 'setup_observability_stack')
setup_observability_stack("development")
{{ end }}
{{ if hasItem .Project.Spec.Infrastructure.Components "langfuse" }}
# Langfuse LLM Observability
load('./k8s/helm/infra/langfuse/Tiltfile', 'setup_langfuse')
setup_langfuse("development")
{{ end }}

# Local-only infrastructure (postgres, redis, etc.)
include('./k8s/deployment/infra/local/Tiltfile')

# ==============================================================================
# Dev Tools
# ==============================================================================
load('./utils/tilt/dev.utils.tilt', 'dev_resources')
dev_resources()

# ==============================================================================
# IRONPLATE:INFRA:START
# ==============================================================================
# Infrastructure entries will be added here by 'iron add'
# ==============================================================================
# IRONPLATE:INFRA:END
