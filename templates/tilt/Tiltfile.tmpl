# =============================================================================
# {{ .Computed.NamePascal }} Platform - Tiltfile
# =============================================================================
# Registry-driven local development orchestrator.
# Services and infra are declared in tilt/registry.yaml.
# Profiles are defined in tilt/profiles.yaml.
#
# This file should NOT need editing when adding services.
# Use: iron generate service <name> --type <type> --group <group>
# =============================================================================

# --- Utilities ---
{{ if .Computed.HasNode }}load('./utils/tilt/node.tilt', 'node_service', 'client_node_service')
{{ end }}{{ if .Computed.HasGo }}load('./utils/tilt/go.utils.tilt', 'go_service')
{{ end }}load('./utils/tilt/dev.utils.tilt', 'get_dev_tool_deps'{{ if .Computed.HasGo }}, 'get_go_dev_tool_deps'{{ end }})
load('./utils/tilt/registry.tilt',
     'register_builders',
     'resolve_profile',
     'setup_services',
     'setup_infra',
     'get_enabled_resources',
     'print_profile_summary')

# --- Tilt settings ---
docker_prune_settings(max_age_mins=60, num_builds=2, keep_recent=1)
update_settings(max_parallel_updates=3, k8s_upsert_timeout_secs=60)
allow_k8s_contexts('k3d-{{ .Project.Metadata.Name }}')

# --- Profile resolution ---
config.define_string('profile', args=True, usage='Tilt profile (minimal/core/full/infra-only)')
cfg = config.parse()
profile = resolve_profile(cfg.get('profile', ''))
print_profile_summary(profile)

target = 'development'

# --- Register service builders ---
register_builders({
{{ if .Computed.HasNode }}    'node-api': node_service,
    'nextjs': client_node_service,
{{ end }}{{ if .Computed.HasGo }}    'go-api': go_service,
{{ end }}})

# --- Infrastructure (from registry) ---
setup_infra(target, profile)

# --- Local-only resources (postgres, redis, pgadmin, traefik) ---
include('./k8s/deployment/local/Tiltfile')

# --- Dev tools ---
load('./utils/tilt/dev.utils.tilt', 'dev_resources')
dev_resources()

# --- Services (from registry) ---
setup_services(target, profile)

# --- Apply profile resource filter ---
enabled = get_enabled_resources(profile)
if enabled != None:
    config.set_enabled_resources(enabled)
