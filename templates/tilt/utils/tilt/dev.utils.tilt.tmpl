# =============================================================================
# Development Tools - Tilt Resources
# =============================================================================
# Manages dev tool resources with proper startup ordering:
#
# PHASE 1 (Build):
#   packages-build    → Initial TypeScript package compilation
{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }}#   gql-codegen-init  → Initial GraphQL codegen
{{ end }}#
# PHASE 2 (Parallel):
#   - All services start (depend on packages-build)
#   - packages-watch starts (depends only on packages-build)
#
# PHASE 3 (On-demand):
#   - helm-lib-watcher → Updates Helm chart deps when _lib templates change
# =============================================================================
{{ if .Computed.HasNode }}
# Standard dependencies that Node.js services should have
DEV_TOOL_DEPS = ['packages-build'{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }}, 'gql-codegen-init'{{ end }}]
{{ end }}
{{ if .Computed.HasGo }}
# Standard dependencies that Go services should have
GO_DEV_TOOL_DEPS = ['go-mod-tidy']
{{ end }}

def get_dev_tool_deps():
    """Get dev tool dependencies that Node.js services should wait for."""
{{ if .Computed.HasNode }}    return DEV_TOOL_DEPS{{ else }}    return []{{ end }}

{{ if .Computed.HasGo }}
def get_go_dev_tool_deps():
    """Get dev tool dependencies that Go services should wait for."""
    return GO_DEV_TOOL_DEPS
{{ end }}

def dev_resources():
    """Set up development tool resources with proper ordering."""
{{ if .Computed.HasNode }}
    # =========================================================================
    # PHASE 0: Install Dependencies
    # =========================================================================

    local_resource(
        '{{ .Project.Spec.Monorepo.PackageManager }}-install',
        cmd='''
            echo "📦 Installing Node dependencies..."
            {{ .Project.Spec.Monorepo.PackageManager }}{{ if eq .Project.Spec.Monorepo.PackageManager "yarn" }}{{ else }} install{{ end }}
            echo "✅ Node dependencies installed!"
        ''',
        labels=['01_dev-tools'],
        auto_init=True,
    )
{{ end }}
{{ if .Computed.HasGo }}
    # Sync Go workspace and tidy all modules
    local_resource(
        'go-mod-tidy',
        cmd='''
            echo "📦 Syncing Go workspace..."
            go work sync
            echo "📦 Running go mod tidy on workspace modules..."
            for mod in $(go work edit -json | jq -r '.Use[].DiskPath'); do
                echo "  → Tidying $mod"
                (cd "$mod" && go mod tidy)
            done
            echo "✅ Go modules synced and tidied!"
        ''',
        labels=['01_dev-tools'],
        auto_init=True,
    )
{{ end }}
{{ if .Computed.HasNode }}
    # =========================================================================
    # PHASE 1: Initial Build (blocks services)
    # =========================================================================

    local_resource(
        'packages-build',
        cmd='''
            echo "📦 Building TypeScript packages..."
            npm run build:all
            echo "✅ All packages built successfully!"
        ''',
        resource_deps=['{{ .Project.Spec.Monorepo.PackageManager }}-install'],
        labels=['01_dev-tools'],
        auto_init=True,
    )
{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }}
    # Run initial GraphQL codegen
    local_resource(
        'gql-codegen-init',
        cmd='''
            echo "🔄 Running initial GraphQL codegen..."
            HASURA_GRAPHQL_ADMIN_SECRET={{ .Project.Metadata.Name }} {{ .Project.Spec.Monorepo.PackageManager }} gql:codegen
            echo "✅ GraphQL types generated!"
        ''',
        resource_deps=['hasura-setup', 'packages-build'],
        labels=['01_dev-tools'],
        auto_init=True,
    )
{{ end }}
    # =========================================================================
    # PHASE 3: Watch Mode (starts after initial build)
    # =========================================================================

    local_resource(
        'packages-watch',
        serve_cmd='''
            echo "👀 Starting TypeScript package watch mode..."
            npm run watch:packages:tsc
        ''',
        resource_deps=['packages-build'],
        labels=['01_dev-tools'],
        auto_init=True,
    )
{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }}
    local_resource(
        'gql-codegen-watch',
        serve_cmd='''
            echo "👀 Watching GraphQL files for changes..."
            npx nodemon \
                --watch 'apps/*/src/graphql/**/*.graphql' \
                --ext 'graphql,gql' \
                --ignore '**/generated/**' \
                --delay 2 \
                --exec 'echo "🔄 GraphQL files changed, regenerating..." && HASURA_GRAPHQL_ADMIN_SECRET={{ .Project.Metadata.Name }} {{ .Project.Spec.Monorepo.PackageManager }} gql:codegen && echo "✅ Codegen complete!"'
        ''',
        resource_deps=['gql-codegen-init'],
        labels=['01_dev-tools'],
        auto_init=True,
    )
{{ end }}
{{ end }}
