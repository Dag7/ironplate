{
  "name": "{{ .Computed.PrimaryScope }}/{{ .Service.Name }}",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:nx": "nx build",
    "start": "node dist/index.js",
    "start:dev": "NODE_ENV=development node ../../scripts/utils/nodemon-runner.cjs --inspect=0.0.0.0:{{ .Service.DebugPort }}",
    "watch": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "compression": "^1.7.5",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "@ironplate/logger": "^0.0.1",
    "@ironplate/config": "^0.0.1",
    "@ironplate/errors": "^0.0.1",
    "@ironplate/health": "^0.0.1",
    "@ironplate/http-client": "^0.0.1"{{ if hasItem .Service.Features "eventbus" }},
    "@ironplate/eventbus": "^0.0.1"{{ end }}{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }},
    "@ironplate/graphql": "^0.0.1"{{ end }}{{ if hasItem .Project.Spec.Infrastructure.Components "redis" }},
    "@ironplate/cache": "^0.0.1"{{ end }}
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "nodemon": "^3.1.0",
    "vitest": "^2.1.0"
  }
}
