package config

import (
	"os"
	"strconv"
)

// Config holds the service configuration.
type Config struct {
	Port     int
	LogLevel string
	Env      string{{ if hasItem .Service.Features "dapr" }}
	DaprHTTPPort int
	DaprGRPCPort int{{ end }}
}

// Load reads configuration from environment variables with defaults.
func Load() *Config {
	return &Config{
		Port:     getIntEnv("PORT", 3000),
		LogLevel: getStringEnv("LOG_LEVEL", "info"),
		Env:      getStringEnv("APP_ENV", "development"),{{ if hasItem .Service.Features "dapr" }}
		DaprHTTPPort: getIntEnv("DAPR_HTTP_PORT", 3500),
		DaprGRPCPort: getIntEnv("DAPR_GRPC_PORT", 50001),{{ end }}
	}
}

func getStringEnv(key, fallback string) string {
	if v := os.Getenv(key); v != "" {
		return v
	}
	return fallback
}

func getIntEnv(key string, fallback int) int {
	if v := os.Getenv(key); v != "" {
		if i, err := strconv.Atoi(v); err == nil {
			return i
		}
	}
	return fallback
}
