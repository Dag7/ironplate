load('../../../../utils/tilt/k8s/helm.utils.tilt', 'ensure_helm_deps')

def setup_{{ snakeCase .Service.Group }}():
    """
    Setup {{ .Service.Group }} services.
    Applies the rendered Helm YAML to K8s.
    """
    # ensure_helm_deps needs path from project root (it joins with config.main_dir)
    ensure_helm_deps("k8s/helm/{{ .Project.Metadata.Name }}/{{ .Service.Group }}")

    # helm() resolves relative to this Tiltfile's directory (which IS the chart dir)
