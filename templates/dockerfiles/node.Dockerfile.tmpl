# syntax=docker/dockerfile:1.4
ARG NODE_VERSION=node:{{ .Project.Spec.Monorepo.NodeVersion }}-alpine

# =============================================================================
# Stage: base - Common setup for all stages
# =============================================================================
FROM ${NODE_VERSION} AS base
ARG TARGET_NAME
ARG TARGET_SRC=apps
ARG WORKSPACE_NAME
ENV TARGET_NAME=${TARGET_NAME}
ENV TARGET_SRC=${TARGET_SRC}
ENV WORKSPACE_NAME=${WORKSPACE_NAME:-{{ .Computed.PrimaryScope }}/${TARGET_NAME}}
WORKDIR /app

# Install build dependencies (cleaned up in production stage)
RUN apk add --no-cache python3 make g++ libc6-compat
RUN corepack enable && corepack prepare {{ .Project.Spec.Monorepo.PackageManager }}@stable --activate

COPY package.json {{ .Project.Spec.Monorepo.PackageManager }}.lock{{ if eq .Project.Spec.Monorepo.PackageManager "yarn" }} .yarnrc.yml{{ end }} ./
{{ if eq .Project.Spec.Monorepo.PackageManager "yarn" }}COPY .yarn/ .yarn/{{ end }}
COPY nx.json tsconfig.json tsconfig.base.json ./
COPY apps ./apps
COPY packages/node ./packages/node
COPY scripts ./scripts

# =============================================================================
# Stage: install-dev - Fast install for development (no nx needed)
# =============================================================================
FROM base AS install-dev
ENV NODE_ENV=development
{{ if eq .Project.Spec.Monorepo.PackageManager "yarn" }}RUN --mount=type=cache,id=yarn-cache,target=/app/.yarn/cache \
    yarn workspaces focus ${WORKSPACE_NAME}{{ else }}RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install --filter ${WORKSPACE_NAME}{{ end }}

# =============================================================================
# Stage: install-build - Full install for production builds (includes nx)
# =============================================================================
FROM base AS install-build
ENV NODE_ENV=development
{{ if eq .Project.Spec.Monorepo.PackageManager "yarn" }}RUN --mount=type=cache,id=yarn-cache,target=/app/.yarn/cache \
    yarn install{{ else }}RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm install{{ end }}

# =============================================================================
# Stage: build - Production build
# =============================================================================
FROM install-build AS build
ENV NODE_ENV=production
RUN --mount=type=cache,id=nx-cache,target=/app/.nx/cache \
    {{ if eq .Project.Spec.Monorepo.PackageManager "yarn" }}yarn{{ else }}pnpm{{ end }} nx build ${TARGET_NAME}
# Prune to only production dependencies
{{ if eq .Project.Spec.Monorepo.PackageManager "yarn" }}RUN --mount=type=cache,id=yarn-cache,target=/app/.yarn/cache \
    yarn workspaces focus ${WORKSPACE_NAME} --production{{ else }}RUN --mount=type=cache,id=pnpm-store,target=/root/.local/share/pnpm/store \
    pnpm prune --prod{{ end }}

# =============================================================================
# Stage: test - Run tests (needs nx)
# =============================================================================
FROM install-build AS test
RUN --mount=type=cache,id=nx-cache,target=/app/.nx/cache \
    {{ if eq .Project.Spec.Monorepo.PackageManager "yarn" }}yarn{{ else }}pnpm{{ end }} nx test ${TARGET_NAME}

# =============================================================================
# Stage: debug
# =============================================================================
FROM build AS debug
CMD ["tail", "-f", "/dev/null"]

# =============================================================================
# Stage: development - For local development with hot reload
# =============================================================================
FROM install-dev AS development
ENV NODE_ENV=development
WORKDIR /app/${TARGET_SRC}/${TARGET_NAME}
CMD ["npm", "run", "start:dev"]

# =============================================================================
# Stage: production - Hardened production image
# =============================================================================
FROM ${NODE_VERSION} AS production
ARG TARGET_NAME
ARG TARGET_SRC=apps

LABEL org.opencontainers.image.source="https://github.com/{{ .Project.Metadata.Organization }}/{{ .Project.Metadata.Name }}"
LABEL org.opencontainers.image.vendor="{{ .Project.Metadata.Organization }}"

WORKDIR /app

# Create non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 appuser

ENV NODE_ENV=production
ENV PORT=3000

# Copy production artifacts
COPY --from=build --chown=appuser:nodejs /app/${TARGET_SRC}/${TARGET_NAME}/dist ./dist
COPY --from=build --chown=appuser:nodejs /app/${TARGET_SRC}/${TARGET_NAME}/package*.json ./
COPY --from=build --chown=appuser:nodejs /app/node_modules ./node_modules
{{ if eq .Project.Spec.Monorepo.PackageManager "yarn" }}COPY --from=build --chown=appuser:nodejs /app/.yarnrc.yml ./{{ end }}

# Copy workspace packages (required for {{ .Computed.PrimaryScope }}/* symlinks)
COPY --from=build --chown=appuser:nodejs /app/packages/node ./packages/node

# Security Hardening: Remove shell and package managers
RUN rm -f /bin/sh /bin/ash /bin/bash /sbin/apk \
    /usr/bin/wget /usr/bin/curl \
    /usr/local/bin/npm /usr/local/bin/npx /usr/local/bin/yarn /usr/local/bin/corepack \
    2>/dev/null || true

USER appuser

EXPOSE 3000

ENTRYPOINT ["node"]
CMD ["dist/index.js"]
