version: 2

updates:
{{ if .Computed.HasNode }}  # NPM - {{ .Project.Spec.Monorepo.PackageManager }} workspaces
  - package-ecosystem: npm
    directory: /
    schedule:
      interval: weekly
      day: monday
    open-pull-requests-limit: 10
    groups:
      minor-and-patch:
        update-types:
          - minor
          - patch
{{ end }}
{{ if .Computed.HasGo }}  # Go modules
  - package-ecosystem: gomod
    directories:
      - /**
    schedule:
      interval: weekly
      day: monday
    open-pull-requests-limit: 5
    groups:
      go-minor-and-patch:
        update-types:
          - minor
          - patch
{{ end }}
  # Docker base images
  - package-ecosystem: docker
    directories:
      - /**
    schedule:
      interval: weekly
    open-pull-requests-limit: 5

  # GitHub Actions
  - package-ecosystem: github-actions
    directory: /
    schedule:
      interval: weekly
      day: monday
    open-pull-requests-limit: 5
    groups:
      actions-minor-and-patch:
        update-types:
          - minor
          - patch
