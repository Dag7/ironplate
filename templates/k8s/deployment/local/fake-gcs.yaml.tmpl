# =============================================================================
# Fake GCS Server - Local GCS Emulator
# =============================================================================
# Emulates Google Cloud Storage for local development.
# No real GCP credentials needed.
#
# Architecture:
#   nginx (port 4443) -> fake-gcs-server (port 4444)
#   nginx rewrites /b/{bucket}/o/{object} -> /download/storage/v1/b/{bucket}/o/{object}
#   This fixes compatibility with @google-cloud/storage SDK download paths.
# =============================================================================
apiVersion: v1
kind: ConfigMap
metadata:
  name: fake-gcs-nginx-config
  namespace: {{ .Project.Metadata.Name }}
data:
  nginx.conf: |
    events {
      worker_connections 1024;
    }
    http {
      server {
        listen 4443;

        # Health check endpoint
        location = /health {
          return 200 'OK';
          add_header Content-Type text/plain;
        }

        # Rewrite /b/{bucket}/o?prefix=... to /storage/v1/b/{bucket}/o?prefix=...
        # This fixes @google-cloud/storage SDK list objects requests
        location ~ ^/b/([^/]+)/o$ {
          rewrite ^/b/([^/]+)/o$ /storage/v1/b/$1/o break;
          proxy_pass http://127.0.0.1:4444;
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
        }

        # Rewrite /b/{bucket}/o/{object} to /download/storage/v1/b/{bucket}/o/{object}
        # This fixes @google-cloud/storage SDK download URL format
        location ~ ^/b/([^/]+)/o/(.+)$ {
          rewrite ^/b/([^/]+)/o/(.+)$ /download/storage/v1/b/$1/o/$2 break;
          proxy_pass http://127.0.0.1:4444;
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
        }

        # All other requests pass through directly
        location / {
          proxy_pass http://127.0.0.1:4444;
          proxy_set_header Host $host;
          proxy_set_header X-Real-IP $remote_addr;
          # Support large uploads
          client_max_body_size 100M;
        }
      }
    }
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: {{ .Project.Metadata.Name }}-fake-gcs-data
  namespace: {{ .Project.Metadata.Name }}
spec:
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 5Gi
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: fake-gcs
  namespace: {{ .Project.Metadata.Name }}
  labels:
    app.kubernetes.io/name: fake-gcs
    app.kubernetes.io/part-of: {{ .Project.Metadata.Name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app: fake-gcs
  template:
    metadata:
      labels:
        app: fake-gcs
    spec:
      initContainers:
        - name: create-buckets
          image: busybox:1.36
          command: ['sh', '-c']
          args:
            - |
              mkdir -p /data/{{ .Project.Metadata.Name }}-files-dev
              mkdir -p /data/{{ .Project.Metadata.Name }}-uploads-dev
          volumeMounts:
            - name: gcs-data
              mountPath: /data
      containers:
        # Nginx proxy to fix download URL paths
        - name: nginx
          image: nginx:1.25-alpine
          ports:
            - containerPort: 4443
              name: http
          volumeMounts:
            - name: nginx-config
              mountPath: /etc/nginx/nginx.conf
              subPath: nginx.conf
          resources:
            requests:
              memory: 32Mi
              cpu: 10m
            limits:
              memory: 64Mi
              cpu: 100m
          readinessProbe:
            httpGet:
              path: /health
              port: 4443
            initialDelaySeconds: 2
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /health
              port: 4443
            initialDelaySeconds: 5
            periodSeconds: 10
        # Fake GCS server on internal port 4444
        - name: fake-gcs
          image: fsouza/fake-gcs-server:1.52.3
          args:
            - "-scheme"
            - "http"
            - "-port"
            - "4444"
            - "-public-host"
            - "fake-gcs:4443"
            - "-external-url"
            - "http://fake-gcs:4443"
            - "-backend"
            - "filesystem"
            - "-filesystem-root"
            - "/data"
          ports:
            - containerPort: 4444
          volumeMounts:
            - name: gcs-data
              mountPath: /data
          resources:
            requests:
              memory: 256Mi
              cpu: 100m
            limits:
              memory: 512Mi
              cpu: 500m
      volumes:
        - name: gcs-data
          persistentVolumeClaim:
            claimName: {{ .Project.Metadata.Name }}-fake-gcs-data
        - name: nginx-config
          configMap:
            name: fake-gcs-nginx-config
---
apiVersion: v1
kind: Service
metadata:
  name: fake-gcs
  namespace: {{ .Project.Metadata.Name }}
  labels:
    app.kubernetes.io/name: fake-gcs
    app.kubernetes.io/part-of: {{ .Project.Metadata.Name }}
spec:
  type: ClusterIP
  ports:
    - port: 4443
      targetPort: 4443
      protocol: TCP
      name: http
  selector:
    app: fake-gcs
