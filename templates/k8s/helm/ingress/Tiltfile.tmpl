# Load utilities
load('../../../../utils/tilt/k8s/helm.utils.tilt', 'ensure_helm_deps')

def setup_ingress():
    """Deploy centralized ingress routes via Traefik (*.localhost:8081)."""
    # ensure_helm_deps uses config.main_dir internally, so pass the full project-root-relative path
    ensure_helm_deps("k8s/helm/{{ .Project.Metadata.Name }}/ingress")

    # helm() resolves relative to this Tiltfile's directory, which is already the chart dir
    k8s_yaml(helm(
        ".",
        name="ingress",
        namespace="{{ .Project.Metadata.Name }}",
        values=[
            "./values.yaml"
        ]
    ))

setup_ingress()
