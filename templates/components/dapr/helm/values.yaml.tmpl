# =============================================================================
# Dapr Configuration - Development Values
# =============================================================================

# Namespace for Dapr components (used by our custom templates)
namespace: {{ .Project.Metadata.Name }}

# Whether to create the namespace (set to false if namespace is managed elsewhere)
createNamespace: false

# =============================================================================
# Dapr Subchart Values (passed to the dapr dependency chart)
# =============================================================================
dapr:
  # RBAC settings
  # Disable secret-reader in 'default' namespace - we don't use default namespace
  # All our workloads run in '{{ .Project.Metadata.Name }}' namespace with explicit service accounts
  dapr_rbac:
    secretReader:
      enabled: false

  # Global settings
  global:
    # mTLS settings - keep enabled but with auto-generated certs
    # This is simpler than trying to disable it completely
    mtls:
      enabled: true
      workloadCertTTL: 24h
      allowedClockSkew: 15m
    # Logging
    logAsJson: true

  # Dapr Operator
  dapr_operator:
    replicaCount: 1
    logLevel: info
    # Increase probe delays to prevent restarts during startup
    # Operator needs time to fetch certs from sentry and acquire leader lease
    livenessProbe:
      initialDelaySeconds: 30
      periodSeconds: 10
      failureThreshold: 5
    readinessProbe:
      initialDelaySeconds: 10
      periodSeconds: 5
      failureThreshold: 5

  # Dapr Sidecar Injector
  dapr_sidecar_injector:
    enabled: true
    logLevel: info
    livenessProbe:
      initialDelaySeconds: 30
      periodSeconds: 10
      failureThreshold: 5
    readinessProbe:
      initialDelaySeconds: 10
      periodSeconds: 5
      failureThreshold: 5

  # Dapr Placement Service
  dapr_placement:
    replicaCount: 1
    logLevel: info
    livenessProbe:
      initialDelaySeconds: 30
      periodSeconds: 10
      failureThreshold: 5
    readinessProbe:
      initialDelaySeconds: 10
      periodSeconds: 5
      failureThreshold: 5

  # Dapr Sentry (Certificate Authority) - ENABLED to generate trust bundle
  dapr_sentry:
    enabled: true
    replicaCount: 1
    logLevel: info
    livenessProbe:
      initialDelaySeconds: 30
      periodSeconds: 10
      failureThreshold: 5
    readinessProbe:
      initialDelaySeconds: 10
      periodSeconds: 5
      failureThreshold: 5
    # Trust domain for mTLS
    trustDomain: cluster.local
    # Longer TTLs for dev environment to avoid frequent cert expiration
    # Default issuer cert is 1h which is too short for dev
    tokenAudience: "dapr.io/sentry"
    tls:
      issuer:
        certPEM: ""
        keyPEM: ""
        expiry: "8760h"  # 1 year for issuer cert
      root:
        certPEM: ""
        keyPEM: ""
        expiry: "8760h"  # 1 year for root CA

  # Dapr Dashboard
  dapr_dashboard:
    enabled: false

# =============================================================================
# Kafka Pub/Sub Component
# =============================================================================
components:
  kafkaPubsub:
    enabled: {{ if .Computed.HasKafka }}true{{ else }}false{{ end }}
    name: kafka-pubsub
    type: pubsub.kafka
    version: v1
    metadata:
      - name: brokers
        value: "{{ .Project.Metadata.Name }}-kafka-kafka-bootstrap.kafka:9092"
      # NOTE: Do NOT set consumerGroup here. Each subscription defines its own
      # consumer group via metadata.consumerGroup in the Subscription resource.
      # A global consumer group causes all services to share one group, meaning
      # messages are distributed instead of each service receiving all messages.
      - name: clientID
        value: "{{ .Project.Metadata.Name }}-dapr"
      - name: authType
        value: "none"
      - name: disableTls
        value: "true"
      - name: maxMessageBytes
        value: "1048576"
      - name: consumeRetryInterval
        value: "100ms"
      # Start from latest offset on new consumer groups (prevents reprocessing on restart)
      - name: initialOffset
        value: "newest"

# =============================================================================
# Resiliency Policies
# =============================================================================
resiliency:
  enabled: true
  policies:
    retries:
      traceRetry:
        policy: exponential
        maxRetries: 3
        duration: 100ms
        maxInterval: 5s
      cdcRetry:
        policy: constant
        maxRetries: 5
        duration: 500ms
      triggerRetry:
        policy: exponential
        maxRetries: 3
        duration: 1s
        maxInterval: 30s
    circuitBreakers:
      externalCB:
        maxRequests: 5
        interval: 10s
        timeout: 30s
        trip: consecutiveFailures >= 3
  targets:
    components:
      kafka-pubsub:
        inbound:
          retry: traceRetry
        outbound:
          retry: traceRetry

# =============================================================================
# Subscriptions
# =============================================================================
# NOTE: Subscriptions are now defined per-service in their own values.yaml files.
#
# Each service that needs subscriptions defines them directly in their Helm values.
# This keeps subscriptions close to the services that consume them and
# enables proper dependency tracking in Tilt.
subscriptions: {}
