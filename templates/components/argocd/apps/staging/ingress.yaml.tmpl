# =============================================================================
# ArgoCD Ingress Application - Staging
# =============================================================================
# Centralized ingress routing for all services.
# Sync Wave: 2 (after infrastructure, before services)
# =============================================================================
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: ingress-staging
  namespace: argocd
  labels:
    app.kubernetes.io/part-of: {{ .Project.Metadata.Name }}
    app.kubernetes.io/component: ingress
    environment: staging
  annotations:
    argocd.argoproj.io/sync-wave: "2"
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: {{ .Project.Metadata.Name }}-staging

  source:
    repoURL: https://github.com/{{ .Project.Metadata.Organization }}/{{ .Project.Metadata.Name }}.git
    targetRevision: staging
    path: k8s/helm/ingress
    helm:
      valueFiles:
        - values.yaml
        - values-staging.yaml

  destination:
    server: https://kubernetes.default.svc
    namespace: {{ .Project.Metadata.Name }}

  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - RespectIgnoreDifferences=true
    retry:
      limit: 5
      backoff:
        duration: 5s
        factor: 2
        maxDuration: 3m

  revisionHistoryLimit: 5
