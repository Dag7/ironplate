# =============================================================================
# ArgoCD Root Application - {{ .Project.Metadata.Name }} Apps (Production)
# =============================================================================
# App-of-Apps that generates Application resources for each service group.
# Sync Wave: 2 (after infrastructure, before services)
# =============================================================================
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: {{ .Project.Metadata.Name }}-apps-production
  namespace: argocd
  labels:
    app.kubernetes.io/part-of: {{ .Project.Metadata.Name }}
    app.kubernetes.io/component: app-of-apps
    environment: production
  annotations:
    argocd.argoproj.io/sync-wave: "2"
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: {{ .Project.Metadata.Name }}-production

  source:
    repoURL: https://github.com/{{ .Project.Metadata.Organization }}/{{ .Project.Metadata.Name }}.git
    targetRevision: main
    path: k8s/argocd/charts/apps
    helm:
      valueFiles:
        - values.yaml
        - values-production.yaml

  destination:
    server: https://kubernetes.default.svc
    namespace: argocd

  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - RespectIgnoreDifferences=true
      - PruneLast=true
    retry:
      limit: 5
      backoff:
        duration: 5s
        factor: 2
        maxDuration: 3m

  ignoreDifferences:
    - group: argoproj.io
      kind: Application
      jsonPointers:
        - /status

  revisionHistoryLimit: 10
