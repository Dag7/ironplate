# =============================================================================
# ArgoCD Infrastructure Applications - Production
# =============================================================================
# One Application per infrastructure component, ordered by sync-wave.
# Production uses PruneLast and higher revision history limits.
# =============================================================================
{{ if .Computed.HasExternalSecrets }}
---
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: external-secrets-production
  namespace: argocd
  labels:
    app.kubernetes.io/part-of: {{ .Project.Metadata.Name }}
    app.kubernetes.io/component: external-secrets
    environment: production
  annotations:
    argocd.argoproj.io/sync-wave: "-1"
  finalizers:
    - resources-finalizer.argocd.argoproj.io
spec:
  project: {{ .Project.Metadata.Name }}-production
  source:
    repoURL: https://github.com/{{ .Project.Metadata.Organization }}/{{ .Project.Metadata.Name }}.git
    targetRevision: main
    path: k8s/helm/infra/external-secrets
    helm:
      valueFiles:
        - values.yaml
  destination:
    server: https://kubernetes.default.svc
    namespace: {{ .Project.Metadata.Name }}
  syncPolicy:
    automated:
      prune: false
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
      - RespectIgnoreDifferences=true
    retry:
      limit: 5
      backoff:
        duration: 5s
        factor: 2
        maxDuration: 3m
  revisionHistoryLimit: 10
