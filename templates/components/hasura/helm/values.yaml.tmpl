# =============================================================================
# Hasura GraphQL Engine - Local Development Values
# =============================================================================
# Self-managed Hasura deployment for {{ .Project.Metadata.Name }} platform.
# All environments use secrets (local: k3s manifests, staging/prod: External Secrets)
# =============================================================================

# Namespace
namespace: {{ .Project.Metadata.Name }}

# Global settings
global:
  environment: development

# =============================================================================
# Hasura Deployment Configuration
# =============================================================================
hasura:
  # Image settings
  image:
    repository: hasura/graphql-engine
    tag: v2.40.0
    pullPolicy: IfNotPresent

  # Replicas
  replicas: 1

  # Service configuration
  service:
    type: ClusterIP
    port: 8080

  # Secrets to mount as envFrom (same for all environments)
  # Local: from .devcontainer/k3s/manifests/_secrets/{{ .Project.Metadata.Name }}.yaml
  # Staging/Prod: from External Secrets (GCP Secret Manager)
  secrets:
    - database-credentials
    - hasura-credentials

  # Environment variables from secret keys (for remapping secret keys to different env var names)
  # Hasura requires HASURA_GRAPHQL_ prefix for database URLs
  secretEnv:
    - name: HASURA_GRAPHQL_DATABASE_URL
      secretName: database-credentials
      secretKey: DATABASE_URL
    - name: HASURA_GRAPHQL_METADATA_DATABASE_URL
      secretName: database-credentials
      secretKey: METADATA_DATABASE_URL

  # Environment variables (non-secret config only)
  env:
    # Console settings
    HASURA_GRAPHQL_ENABLE_CONSOLE: "true"
    HASURA_GRAPHQL_DEV_MODE: "true"
    # Logging
    HASURA_GRAPHQL_ENABLED_LOG_TYPES: "startup, http-log, webhook-log, websocket-log, query-log"
    HASURA_GRAPHQL_LOG_LEVEL: "debug"
    # Auth
    HASURA_GRAPHQL_UNAUTHORIZED_ROLE: "anonymous"
    # Connection pooling
    HASURA_GRAPHQL_PG_CONNECTIONS: "10"
    HASURA_GRAPHQL_PG_TIMEOUT: "180"
    # Event trigger webhook URLs (used in Hasura metadata)
    HASURA_EVENT_RELAY_URL: "http://hasura-event-relay:3000"

  # Resource limits
  resources:
    requests:
      memory: "256Mi"
      cpu: "100m"
    limits:
      memory: "1Gi"
      cpu: "1"

  # Probes
  livenessProbe:
    path: /healthz
    port: 8080
    initialDelaySeconds: 30
    periodSeconds: 10
    timeoutSeconds: 5

  readinessProbe:
    path: /healthz
    port: 8080
    initialDelaySeconds: 10
    periodSeconds: 5
    timeoutSeconds: 3

  # Node selection (empty for dev)
  nodeSelector: {}
  tolerations: []
  affinity: {}

# =============================================================================
# Migrations Configuration
# =============================================================================
# Hasura migrations job - runs after Hasura is deployed
# Disabled for local development (use Tilt/manual migrations)
migrations:
  enabled: false # Disabled for local dev
  image:
    registry: {{ .Project.Metadata.Name }}
    tag: latest
    pullPolicy: Always
  hasuraEndpoint: http://hasura:8080
  applySeeds: "true"
  maxRetries: 60
  retryInterval: 5
  debug: false
  resources:
    requests:
      cpu: 100m
      memory: 256Mi
    limits:
      cpu: 500m
      memory: 512Mi
  nodeSelector: {}
  tolerations: []

# =============================================================================
# Ingress Configuration
# =============================================================================
# Disabled for local - central {{ .Project.Metadata.Name }}/ingress chart handles all ingresses
# Enable for staging/production if not using central ingress
ingress:
  enabled: false
  host: hasura.localhost
  className: traefik
  annotations:
    traefik.ingress.kubernetes.io/router.entrypoints: web
  tls:
    enabled: false
    secretName: ""
