# =============================================================================
# Hasura GraphQL Engine - Tiltfile
# =============================================================================
# Deploys Hasura for development with metadata, migrations, and console support
# =============================================================================

# Configuration
HASURA_NAMESPACE = "{{ .Project.Metadata.Name }}"
HASURA_ADMIN_SECRET = "{{ .Project.Metadata.Name }}"  # From .devcontainer/k3s/manifests/_secrets/{{ .Project.Metadata.Name }}.yaml

def setup_hasura(environment):
    """
    Setup Hasura GraphQL Engine.

    Args:
        environment: 'development', 'staging', or 'production'
    """

    # Environment-specific overrides (merged with base values.yaml)
    env_values_file = {
        "development": None,  # Use only base values.yaml
        "staging": "values-staging.yaml",
        "production": "values-prod.yaml",
    }.get(environment)

    chart_path = "k8s/helm/infra/hasura"

    # Build values files list (relative to this Tiltfile's directory)
    values_files = ["./values.yaml"]
    if env_values_file:
        values_files.append("./%s" % env_values_file)

    # Deploy via Helm (path relative to this Tiltfile's directory)
    k8s_yaml(helm(
        ".",
        name="hasura",
        namespace="{{ .Project.Metadata.Name }}",
        values=values_files
    ))

    # Hasura deployment (Service is auto-associated by Tilt)
    # Ingress is handled by central {{ .Project.Metadata.Name }}/ingress chart
    k8s_resource(
        "hasura",
        objects=[
            "hasura:ServiceAccount:{{ .Project.Metadata.Name }}",
        ],
        resource_deps=["postgresql"],
        labels=["hasura"],
        port_forwards=["8080:8080"]
    )

    # Development-only resources
    if environment == "development":
        _setup_development_resources()


def _setup_development_resources():
    """Setup hasura-setup and hasura-console for local development."""

    # Apply metadata, migrations, and seeds
    # Watches hasura directory and auto-applies when metadata files change
    local_resource(
        "hasura-setup",
        dir="/workspaces/{{ .Project.Metadata.Name }}/hasura",
        cmd="""
            set -e
            echo "Applying metadata..."
            hasura metadata apply --admin-secret {secret}
            echo "Applying migrations..."
            hasura migrate apply --all-databases --admin-secret {secret}
            echo "Reloading metadata..."
            hasura metadata reload --admin-secret {secret}
            echo "Applying seeds..."
            hasura seed apply --database-name default --admin-secret {secret} || echo "No seeds to apply"
            echo "Hasura setup complete (metadata, migrations, seeds)"
        """.format(secret=HASURA_ADMIN_SECRET),
        auto_init=True,
        resource_deps=["hasura"],
        labels=["hasura"],
    )

    # Hasura console (manual trigger)
    local_resource(
        "hasura-console",
        serve_dir="/workspaces/{{ .Project.Metadata.Name }}/hasura",
        serve_cmd="hasura console --endpoint http://localhost:8080 --admin-secret {}".format(HASURA_ADMIN_SECRET),
        auto_init=False,
        labels=["hasura"],
    )

setup_hasura('development')
