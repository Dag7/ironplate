# Load utilities
load('../../../../utils/tilt/k8s/pvc.utils.tilt', 'clear_pvc')

def setup_langfuse(environment):
    """
    Setup Langfuse LLM Observability (v3).

    v3 introduces:
    - PostgreSQL (metadata) - local only, Cloud SQL for staging/prod
    - ClickHouse (OLAP database for traces)
    - Worker container (background jobs)
    - Redis (queue/cache) - reuses existing Redis in dev
    - GCS (blob storage) - only in staging/prod

    Args:
        environment: 'development', 'staging', or 'production'
    """

    # Environment-specific overrides (merged with base values.yaml)
    env_values_file = {
        "development": "values-dev.yaml",
        "staging": "values-staging.yaml",
        "production": "values-prod.yaml",
    }.get(environment)

    # Build values files list (relative to this Tiltfile's directory)
    values_files = ["./values.yaml"]
    if env_values_file:
        values_files.append("./%s" % env_values_file)

    # Deploy via Helm (path relative to this Tiltfile's directory)
    k8s_yaml(helm(
        ".",
        name="langfuse",
        namespace="{{ .Project.Metadata.Name }}",
        values=values_files
    ))

    # Base resource dependencies
    web_deps = ["langfuse-clickhouse"]
    worker_deps = ["langfuse-clickhouse"]

    # PostgreSQL StatefulSet (dev only)
    if environment == "development":
        # Clear PVCs for fresh starts
        clear_pvc('data-langfuse-postgres-0')
        clear_pvc('data-langfuse-clickhouse-0')

        # Service is auto-associated by Tilt (selector matches StatefulSet)
        k8s_resource(
            "langfuse-postgres",
            labels=["langfuse"],
        )
        web_deps.append("langfuse-postgres")
        web_deps.append("redis")  # Reuse existing Redis in dev

    # ClickHouse StatefulSet (v3)
    # Service is auto-associated by Tilt (selector matches StatefulSet)
    k8s_resource(
        "langfuse-clickhouse",
        labels=["langfuse"],
    )

    # Langfuse Web deployment
    # Service is auto-associated by Tilt (selector matches Deployment)
    k8s_resource(
        "langfuse",
        objects=[
            "langfuse:ServiceAccount:{{ .Project.Metadata.Name }}",
        ],
        resource_deps=web_deps,
        labels=["langfuse"],
        port_forwards=["4000:80"]  # Port 4000 for local dev
    )

    # Langfuse Worker deployment (v3)
    k8s_resource(
        "langfuse-worker",
        resource_deps=worker_deps + (["redis"] if environment == "development" else []),
        labels=["langfuse"],
    )

    # Note: Langfuse ingress is managed in the root Tiltfile with other infra ingresses

setup_langfuse('development')
