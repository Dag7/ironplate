projectName: {{ .Project.Metadata.Name }}

image:
  repository: redis
  tag: "7.2-alpine"
  pullPolicy: IfNotPresent

replicaCount: 1

persistence:
  enabled: false

resources:
  limits:
    memory: 256Mi
    cpu: 250m
  requests:
    memory: 128Mi
    cpu: 100m

redis:
  maxmemory: "200mb"
  maxmemoryPolicy: "allkeys-lru"

metrics:
  enabled: {{ if .Computed.HasObservability }}true{{ else }}false{{ end }}
  image:
    repository: oliver006/redis_exporter
    tag: "v1.58.0-alpine"
    pullPolicy: IfNotPresent
  resources:
    limits:
      memory: 64Mi
      cpu: 100m
    requests:
      memory: 32Mi
      cpu: 50m

service:
  type: ClusterIP
  port: 6379
