# Load utilities
load('../../../../utils/tilt/k8s/helm.utils.tilt', 'ensure_helm_deps')

def setup_kafka(environment):
    """
    Setup Strimzi Kafka cluster.

    Args:
        environment: 'development', 'staging', or 'production'
    """

    # Environment-specific overrides (merged with base values.yaml)
    env_values_file = {
        "development": None,  # Use only base values.yaml
        "staging": "values-staging.yaml",
        "production": "values-prod.yaml",
    }.get(environment)

    chart_path = "k8s/helm/infra/kafka"

    # Helm dependencies (uses config.main_dir for absolute path)
    ensure_helm_deps(chart_path, "strimzi", "https://strimzi.io/charts/")

    # Build values files list (relative to this Tiltfile's directory)
    values_files = ["./values.yaml"]
    if env_values_file:
        values_files.append("./%s" % env_values_file)

    # Deploy via Helm (path relative to this Tiltfile's directory)
    k8s_yaml(helm(
        ".",
        name="strimzi-kafka",
        namespace="{{ .Project.Metadata.Name }}-kafka",
        values=values_files
    ))

    # Kafka Namespace - must exist before any kafka resources
    k8s_resource(
        new_name="kafka-namespace",
        objects=["{{ .Project.Metadata.Name }}-kafka:namespace"],
        labels=["kafka"]
    )

    # Strimzi Bootstrap - applies all Strimzi resources in correct order
    # This fixes race conditions where Deployment is created before ClusterRoles
    local_resource(
        "strimzi-bootstrap",
        cmd="""
            echo "Bootstrapping Strimzi resources..."
            helm template strimzi-kafka ./%s --namespace {{ .Project.Metadata.Name }}-kafka --values ./%s/values.yaml | \
                kubectl apply --server-side -f - 2>&1 | grep -v "unchanged" || true
            echo "Waiting for ClusterRoles..."
            kubectl wait --for=jsonpath='{.metadata.name}'=strimzi-cluster-operator-global clusterrole/strimzi-cluster-operator-global --timeout=30s
            echo "Strimzi bootstrap complete"
        """ % (chart_path, chart_path),
        resource_deps=["kafka-namespace"],
        labels=["kafka"]
    )

    # Strimzi CRDs (cluster-scoped, no namespace)
    # Updated for Strimzi 0.49.1 - kafkamirrormakers removed (use kafkamirrormaker2s instead)
    k8s_resource(
        new_name="strimzi-crds",
        resource_deps=["strimzi-bootstrap"],
        objects=[
            "kafkas.kafka.strimzi.io:CustomResourceDefinition",
            "kafkaconnects.kafka.strimzi.io:CustomResourceDefinition",
            "strimzipodsets.core.strimzi.io:CustomResourceDefinition",
            "kafkatopics.kafka.strimzi.io:CustomResourceDefinition",
            "kafkausers.kafka.strimzi.io:CustomResourceDefinition",
            "kafkanodepools.kafka.strimzi.io:CustomResourceDefinition",
            "kafkabridges.kafka.strimzi.io:CustomResourceDefinition",
            "kafkaconnectors.kafka.strimzi.io:CustomResourceDefinition",
            "kafkamirrormaker2s.kafka.strimzi.io:CustomResourceDefinition",
            "kafkarebalances.kafka.strimzi.io:CustomResourceDefinition",
        ],
        labels=["kafka"]
    )

    # Strimzi RBAC
    # Note: Operator runs in project-kafka namespace (same as release namespace)
    # ClusterRoles and ClusterRoleBindings are cluster-scoped (no namespace)
    k8s_resource(
        new_name="strimzi-rbac",
        objects=[
            # Namespaced resources (in kafka namespace where operator runs)
            "strimzi-cluster-operator:ServiceAccount:{{ .Project.Metadata.Name }}-kafka",
            "strimzi-cluster-operator:ConfigMap:{{ .Project.Metadata.Name }}-kafka",
            # Cluster-scoped resources (no namespace)
            "strimzi-cluster-operator-namespaced:ClusterRole",
            "strimzi-cluster-operator-global:ClusterRole",
            "strimzi-cluster-operator-leader-election:ClusterRole",
            "strimzi-cluster-operator-watched:ClusterRole",
            "strimzi-kafka-broker:ClusterRole",
            "strimzi-entity-operator:ClusterRole",
            "strimzi-kafka-client:ClusterRole",
            "strimzi-cluster-operator:ClusterRoleBinding",
            "strimzi-cluster-operator-kafka-broker-delegation:ClusterRoleBinding",
            "strimzi-cluster-operator-kafka-client-delegation:ClusterRoleBinding",
            # RoleBindings in kafka namespace
            "strimzi-cluster-operator:RoleBinding:{{ .Project.Metadata.Name }}-kafka",
            "strimzi-cluster-operator-leader-election:RoleBinding:{{ .Project.Metadata.Name }}-kafka",
            "strimzi-cluster-operator-watched:RoleBinding:{{ .Project.Metadata.Name }}-kafka",
            "strimzi-cluster-operator-entity-operator-delegation:RoleBinding:{{ .Project.Metadata.Name }}-kafka",
        ],
        resource_deps=["strimzi-crds"],
        labels=["kafka"]
    )

    # Strimzi Operator
    k8s_resource(
        "strimzi-cluster-operator",
        resource_deps=["strimzi-rbac"],
        labels=["kafka"]
    )

    # Kafka Cluster
    kafka_cluster_objects = [
        "{{ .Project.Metadata.Name }}-kafka:Kafka:{{ .Project.Metadata.Name }}-kafka",
        "{{ .Project.Metadata.Name }}-kafka-pool:KafkaNodePool:{{ .Project.Metadata.Name }}-kafka",
    ]

{{ if .Computed.HasObservability }}    # Metrics configmap (metricsConfig.enabled=true when observability is active)
    kafka_cluster_objects.append("{{ .Project.Metadata.Name }}-kafka-metrics:configmap:{{ .Project.Metadata.Name }}-kafka")
{{ end }}

    k8s_resource(
        new_name="kafka-cluster",
        objects=kafka_cluster_objects,
        resource_deps=["strimzi-cluster-operator"],
        labels=["kafka"]
    )

    # Kafka Ready - waits for Kafka broker pods to be fully operational
    # First waits for pods to exist, then waits for them to be Ready
    local_resource(
        "kafka-ready",
        cmd="""
            echo "Waiting for Kafka pods to be created..."
            for i in $(seq 1 60); do
                if kubectl get pod -l strimzi.io/cluster={{ .Project.Metadata.Name }}-kafka,strimzi.io/kind=Kafka -n {{ .Project.Metadata.Name }}-kafka 2>/dev/null | grep -q {{ .Project.Metadata.Name }}-kafka; then
                    echo "Kafka pods found, waiting for Ready condition..."
                    kubectl wait pod -l strimzi.io/cluster={{ .Project.Metadata.Name }}-kafka,strimzi.io/kind=Kafka -n {{ .Project.Metadata.Name }}-kafka --for=condition=Ready --timeout=300s
                    exit $?
                fi
                echo "No Kafka pods yet, waiting... ($i/60)"
                sleep 5
            done
            echo "Timeout waiting for Kafka pods to be created"
            exit 1
        """,
        resource_deps=["kafka-cluster"],
        labels=["kafka"]
    )

    # Kafka Topics - only created when topics are defined in values.yaml
    # To add topics, define them in values.yaml under the `topics` array,
    # then add their object references here:
    #   k8s_resource(
    #       new_name="kafka-topics",
    #       objects=[
    #           "<project>-<topic-name>:KafkaTopic:<namespace>",
    #       ],
    #       resource_deps=["kafka-ready"],
    #       labels=["kafka"]
    #   )

    # Kafka UI (dev/staging only)
    # NOTE: Ingress managed centrally via ingress chart with IAP
    if environment in ["development", "staging"]:
        port = "9080:8080" if environment == "development" else "9081:8080"
        k8s_resource(
            "kafka-ui",
            resource_deps=["kafka-cluster"],
            labels=["kafka"],
            port_forwards=[port]
        )

setup_kafka('development')
