# =============================================================================
# Kafka (Strimzi) - Values
# =============================================================================
# Dev-friendly defaults for a single-node Kafka cluster managed by Strimzi.
# =============================================================================

projectName: {{ .Project.Metadata.Name }}

namespace: {{ .Project.Metadata.Name }}-kafka

strimzi:
  operator:
    enabled: true
    # Strimzi operator Helm chart version
    chartVersion: "0.41.0"
    watchNamespaces: []
    resources:
      requests:
        cpu: 100m
        memory: 256Mi
      limits:
        cpu: 500m
        memory: 512Mi

kafka:
  # Cluster name used for the Kafka CR
  clusterName: {{ .Project.Metadata.Name }}-kafka
  version: "3.7.0"
  replicas: 1

  listeners:
    # Internal plain-text listener (in-cluster access)
    plain:
      port: 9092
      type: internal
      tls: false
    # External listener via NodePort (host access from dev machine)
    external:
      port: 9094
      type: nodeport
      tls: false

  storage:
    type: ephemeral
    # For persistent storage (non-dev), uncomment:
    # type: persistent-claim
    # size: 10Gi
    # storageClass: standard

  config:
    # Conservative defaults for local development
    offsets.topic.replication.factor: 1
    transaction.state.log.replication.factor: 1
    transaction.state.log.min.isr: 1
    default.replication.factor: 1
    min.insync.replicas: 1
    log.retention.hours: 24
    log.retention.bytes: 1073741824
    auto.create.topics.enable: "true"

  resources:
    requests:
      cpu: 200m
      memory: 512Mi
    limits:
      cpu: "1"
      memory: 1Gi

  jvmOptions:
    -Xms: 256m
    -Xmx: 512m

# Topics to create automatically (list of objects with name, partitions, replicas, config)
# Example:
#   - name: my-events
#     partitions: 3
#     replicas: 1
#     config:
#       retention.ms: "86400000"
topics: []

kafkaUI:
  enabled: true
  image:
    repository: provectuslabs/kafka-ui
    tag: "v0.7.2"
    pullPolicy: IfNotPresent
  service:
    type: ClusterIP
    port: 8080
  resources:
    requests:
      cpu: 50m
      memory: 128Mi
    limits:
      cpu: 250m
      memory: 256Mi

metrics:
  enabled: {{ .Computed.HasObservability }}
  # JMX exporter configuration for Prometheus scraping
  jmxExporter:
    image:
      repository: bitnami/jmx-exporter
      tag: "0.20.0"
    port: 9404
    resources:
      requests:
        cpu: 50m
        memory: 64Mi
      limits:
        cpu: 200m
        memory: 128Mi
