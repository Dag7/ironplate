# =============================================================================
# Strimzi Kafka Configuration - Development Values
# =============================================================================

# Namespace for Kafka resources
namespace: {{ .Project.Metadata.Name }}-kafka

# Strimzi Operator settings
operator:
  enabled: true
  watchNamespaces: [] # Empty = watch all namespaces
  logLevel: INFO

# =============================================================================
# Kafka Cluster Configuration (KRaft Mode - No Zookeeper)
# =============================================================================
kafka:
  # Cluster name
  name: {{ .Project.Metadata.Name }}-kafka

  # Kafka version
  # Strimzi 0.49.1 supports: 3.8.0, 3.8.1, 3.9.0, 4.0.0
  version: "4.0.0"

  # Replicas (1 for dev, 3 for prod)
  replicas: 1

  # KRaft Mode Configuration
  kraft:
    enabled: true
    # Controller replicas (same as broker in combined mode)
    controllerReplicas: 1

  # Listeners
  listeners:
    # Internal plain listener
    - name: plain
      port: 9092
      type: internal
      tls: false
    # Internal TLS listener (optional, disabled by default in dev)
    - name: tls
      port: 9093
      type: internal
      tls: false # Set to true in production

  # Storage configuration
  storage:
    type: ephemeral # Use 'persistent-claim' for production
    # Persistent storage config (uncomment for production)
    # type: persistent-claim
    # size: 10Gi
    # storageClass: standard
    # deleteClaim: false

  # Resource limits
  resources:
    requests:
      memory: "512Mi"
      cpu: "250m"
    limits:
      memory: "1Gi"
      cpu: "500m"

  # Kafka configuration
  config:
    # Replication settings (adjust for prod)
    offsets.topic.replication.factor: 1
    transaction.state.log.replication.factor: 1
    transaction.state.log.min.isr: 1
    default.replication.factor: 1
    min.insync.replicas: 1

    # Performance tuning
    num.partitions: 6
    log.retention.hours: 24 # 24 hours (dev)
    log.retention.bytes: 104857600 # 100MB max per partition (dev)
    log.segment.bytes: 52428800 # 50MB segments for faster cleanup

    # Network settings
    socket.send.buffer.bytes: 102400
    socket.receive.buffer.bytes: 102400
    socket.request.max.bytes: 104857600

  # Metrics (JMX)
  metricsConfig:
    enabled: {{ .Computed.HasObservability }}

# =============================================================================
# Kafka Topics
# =============================================================================
# Add project-specific topics here. Example:
#   - name: my-project.events
#     partitions: 6
#     replicas: 1
#     config:
#       retention.ms: "86400000"
#       cleanup.policy: delete
#       min.insync.replicas: "1"
topics: []

# =============================================================================
# Kafka Users (SCRAM-SHA-512 authentication)
# =============================================================================
users:
  enabled: false # Enable for production
  # items:
  #   - name: my-producer
  #     authentication:
  #       type: scram-sha-512
  #     authorization:
  #       type: simple
  #       acls:
  #         - resource:
  #             type: topic
  #             name: my-project.events
  #             patternType: literal
  #           operations:
  #             - Write
  #             - Describe

# =============================================================================
# Entity Operator (Topic and User operators)
# =============================================================================
entityOperator:
  enabled: true
  topicOperator:
    enabled: true
    resources:
      requests:
        memory: "256Mi"
        cpu: "100m"
      limits:
        memory: "512Mi"
        cpu: "200m"
  userOperator:
    enabled: true
    resources:
      requests:
        memory: "256Mi"
        cpu: "100m"
      limits:
        memory: "512Mi"
        cpu: "200m"

# =============================================================================
# Kafka UI (Optional - for debugging)
# =============================================================================
# NOTE: Ingress is managed centrally via ingress chart
# with proper IAP authentication. Configure ingress there, not here.
kafkaUI:
  enabled: true
  image: provectuslabs/kafka-ui:latest
  replicas: 1
  resources:
    requests:
      memory: "256Mi"
      cpu: "100m"
    limits:
      memory: "512Mi"
      cpu: "500m"
  service:
    type: ClusterIP
    port: 8080
