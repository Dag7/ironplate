# =============================================================================
# {{ .Project.Metadata.Name }} - Secrets Template
# =============================================================================
# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is gitignored for security.
# =============================================================================
{{ if eq .Project.Spec.Infrastructure.Database.Type "postgresql" }}---
apiVersion: v1
kind: Secret
metadata:
  name: database-credentials
  namespace: {{ .Project.Metadata.Name }}
type: Opaque
stringData:
  DATABASE_URL: "postgresql://postgres:postgres@postgresql:5432/{{ .Project.Metadata.Name }}"{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }}
  METADATA_DATABASE_URL: "postgresql://postgres:postgres@postgresql:5432/hasura_metadata"{{ end }}
{{ end }}{{ if eq .Project.Spec.Infrastructure.Database.Type "mysql" }}---
apiVersion: v1
kind: Secret
metadata:
  name: database-credentials
  namespace: {{ .Project.Metadata.Name }}
type: Opaque
stringData:
  DATABASE_URL: "mysql://root:root@mysql:3306/{{ .Project.Metadata.Name }}"
{{ end }}---
apiVersion: v1
kind: Secret
metadata:
  name: jwt-credentials
  namespace: {{ .Project.Metadata.Name }}
type: Opaque
stringData:
  JWT_SECRET: "<YOUR_JWT_SECRET_MIN_32_CHARS>"
  JWT_ISSUER: "{{ .Project.Metadata.Name }}"
  JWT_AUDIENCE: "{{ .Project.Metadata.Name }}-api"
---
apiVersion: v1
kind: Secret
metadata:
  name: encryption-credentials
  namespace: {{ .Project.Metadata.Name }}
type: Opaque
stringData:
  ENCRYPTION_KEY: "<YOUR_ENCRYPTION_KEY_MIN_32_CHARS>"
{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }}---
apiVersion: v1
kind: Secret
metadata:
  name: hasura-credentials
  namespace: {{ .Project.Metadata.Name }}
type: Opaque
stringData:
  HASURA_GRAPHQL_ADMIN_SECRET: "<YOUR_HASURA_ADMIN_SECRET>"
  HASURA_JWT_SECRET: '{"type":"HS256","key":"<YOUR_JWT_SECRET_SAME_AS_ABOVE>","claims_namespace":"https://hasura.io/jwt/claims"}'
{{ end }}---
apiVersion: v1
kind: Secret
metadata:
  name: oauth-credentials
  namespace: {{ .Project.Metadata.Name }}
type: Opaque
stringData:
  GITHUB_CLIENT_ID: ""
  GITHUB_CLIENT_SECRET: ""
  GOOGLE_CLIENT_ID: ""
  GOOGLE_CLIENT_SECRET: ""
---
apiVersion: v1
kind: Secret
metadata:
  name: llm-credentials
  namespace: {{ .Project.Metadata.Name }}
type: Opaque
stringData:
  OPENAI_API_KEY: ""
  ANTHROPIC_API_KEY: ""
  GOOGLE_API_KEY: ""
  OLLAMA_BASE_URL: "http://host.docker.internal:11434"
{{ if hasItem .Project.Spec.Infrastructure.Components "langfuse" }}---
apiVersion: v1
kind: Secret
metadata:
  name: langfuse-credentials
  namespace: {{ .Project.Metadata.Name }}
type: Opaque
stringData:
  # Server Configuration (used by Langfuse deployment)
  DATABASE_URL: "postgresql://postgres:postgres@langfuse-postgres:5432/postgres?connection_limit=50&pool_timeout=20"
  NEXTAUTH_SECRET: "<YOUR_NEXTAUTH_SECRET_MIN_32_CHARS>"
  SALT: "<YOUR_SALT_MIN_32_CHARS>"
  ENCRYPTION_KEY: "<YOUR_ENCRYPTION_KEY_64_HEX_CHARS>"
  # Client Configuration (used by services connecting to Langfuse)
  LANGFUSE_PUBLIC_KEY: ""
  LANGFUSE_SECRET_KEY: ""
  LANGFUSE_BASE_URL: "http://langfuse.{{ .Project.Metadata.Name }}.svc.cluster.local"
  # Init Configuration
  LANGFUSE_INIT_PROJECT_PUBLIC_KEY: ""
  LANGFUSE_INIT_PROJECT_SECRET_KEY: ""
  LANGFUSE_INIT_USER_PASSWORD: ""
---
apiVersion: v1
kind: Secret
metadata:
  name: langfuse-otel-credentials
  namespace: monitoring
type: Opaque
stringData:
  # auth-header: base64(public_key:secret_key)
  # Generate with: echo -n "pk-lf-xxx:sk-lf-yyy" | base64
  auth-header: "<BASE64_OF_PUBLIC_KEY:SECRET_KEY>"
{{ end }}{{ if hasItem .Project.Spec.Infrastructure.Components "redis" }}---
apiVersion: v1
kind: Secret
metadata:
  name: redis-credentials
  namespace: {{ .Project.Metadata.Name }}
type: Opaque
stringData:
  REDIS_URL: "redis://redis:6379"
{{ end }}
