#!/bin/bash
# =============================================================================
# {{ .Project.Metadata.Name }} - Initialize k3d Cluster
# =============================================================================

set -euo pipefail

base_path="${GITHUB_WORKSPACE:-/workspaces/{{ .Project.Metadata.Name }}}"

# Import dependencies
source "$base_path/.devcontainer/k3s/scripts/logger.sh"
source "$base_path/.devcontainer/k3s/scripts/k3d-utils.sh"
source "$base_path/.devcontainer/k3s/scripts/docker-permissions.sh"

set_docker_permissions

CLUSTER_NAME={{ .Project.Metadata.Name }}-cluster

# Check if cluster exists (grep -c || true to avoid pipefail exit on no match)
IS_K3S_INIT=$(k3d cluster ls 2>/dev/null | grep -c "$CLUSTER_NAME" || true)

# Parse command-line options
while getopts ":fh" opt; do
    case $opt in
    f)
        FORCE_CREATE=true
        ;;
    h)
        show_help
        exit 0
        ;;
    \?)
        echo "Invalid option: -$OPTARG" >&2
        show_help
        exit 1
        ;;
    esac
done

# Force recreate if requested
if [[ $IS_K3S_INIT != '0' && ${FORCE_CREATE:-false} == true ]]; then
    delete_k3s_cluster
    IS_K3S_INIT=0
fi

# Create cluster if it doesn't exist
if [[ $IS_K3S_INIT == '0' ]]; then
    logger_highlight "creating k8s cluster: $CLUSTER_NAME"

    if ! k3d cluster create \
        --config ${CLUSTER_NAME}.config.yaml \
        --registry-config ${CLUSTER_NAME}.registries.yaml \
        --wait \
        --verbose; then
        logger_error "Failed to create cluster. Common causes:"
        logger_error "  - Port conflict: another k3d cluster may be using the same ports"
        logger_error "    Run 'k3d cluster list' to check, then 'k3d cluster stop <name>' to free ports"
        logger_error "  - Docker not running or not accessible"
        exit 1
    fi
else
    logger_info "using existing k8s cluster: $CLUSTER_NAME"
fi

# Ensure cluster is started and kubeconfig is merged
k3d cluster start $CLUSTER_NAME 2>/dev/null || true
k3d kubeconfig merge $CLUSTER_NAME --kubeconfig-switch-context --kubeconfig-merge-default 2>/dev/null

logger_info "waiting for nodes to be ready..."
until kubectl get nodes &>/dev/null; do
    sleep 1
done
logger_success "nodes ready"

# Apply manifests
logger_info "applying manifests"
kubectl apply -f ./manifests/setup/namespace.yaml

# Set default namespace
logger_info "setting k8s context"
kubectl config set-context --current --namespace={{ .Project.Metadata.Name }}
logger_success "k8s context ready"

# Apply secrets (if they exist)
if [ -f ./manifests/_secrets/secrets.yaml ]; then
    kubectl apply -f ./manifests/_secrets/secrets.yaml
    logger_success "secrets applied"
else
    logger_warning "No secrets.yaml found. Copy secrets.template.yaml to secrets.yaml and fill in values."
fi

# Setup K8s Integration SA
kubectl apply -f ./manifests/setup/k8s-integration-sa.yaml

logger_success "cluster initialization complete"
