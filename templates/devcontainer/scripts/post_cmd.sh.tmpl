#!/bin/bash
# =============================================================================
# {{ .Project.Metadata.Name }} - Post-create setup script
# =============================================================================
# Runs after the dev container is created.
# Sets up host config copying, volume permissions, and docker socket.
#
# NOTE: yarn install, go mod tidy, and package builds are handled by Tilt
# (see utils/tilt/dev.utils.tilt). k3d cluster init is handled by
# .devcontainer/k3s/init-cluster.sh.
# =============================================================================

# Set base path
base_path="${GITHUB_WORKSPACE:-/workspaces/{{ .Project.Metadata.Name }}}"

# Source helper scripts
source "$base_path/.devcontainer/scripts/copy_configs.sh"
source "$base_path/.devcontainer/scripts/set-docker-permissions.sh"

{{ if .Computed.HasNode -}}
# Pre-download package manager so Corepack doesn't prompt on first run (Node 24+ enables Corepack by default)
corepack enable
corepack prepare --activate
{{ if eq .Project.Spec.Monorepo.PackageManager "yarn" -}}
yarn config set --home enableTelemetry 0
# Ensure local yarn binary is available (matches bundled yarnPath in .yarnrc.yml)
yarn_version=$(node -p "require('$base_path/package.json').packageManager.split('@')[1]")
if [ ! -f "$base_path/.yarn/releases/yarn-${yarn_version}.cjs" ]; then
    echo "Downloading yarn ${yarn_version} binary..."
    cd "$base_path" && yarn set version "$yarn_version"
fi
{{ end -}}
{{ end -}}

# Disable global git hooks in dev container
git config --global core.hooksPath /dev/null

# ---------------------------------------------------------------------------
# Fix volume permissions (volumes are mounted as root)
# ---------------------------------------------------------------------------
{{ if eq .Project.Spec.Cloud.Provider "gcp" -}}
if [ -d "/home/vscode/.config/gcloud" ]; then
    echo "Fixing gcloud config volume permissions..."
    sudo chown -R vscode:vscode /home/vscode/.config/gcloud
fi

{{ end -}}
if [ -d "/home/vscode/.claude" ]; then
    echo "Fixing Claude config volume permissions..."
    sudo chown -R vscode:vscode /home/vscode/.claude
fi

# ---------------------------------------------------------------------------
# Run setup functions
# ---------------------------------------------------------------------------
set_docker_permissions
copy_host_configs
