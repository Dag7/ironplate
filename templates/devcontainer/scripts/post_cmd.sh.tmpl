#!/usr/bin/env bash
# =============================================================================
# {{ .Project.Metadata.Name }} - Post-create setup script
# =============================================================================
# Runs after the dev container is created.
# Sources helper scripts, fixes permissions, and sets up the dev environment.
# =============================================================================

echo "🚀 Setting up {{ .Project.Metadata.Name }} development environment..."

# Set base path
base_path="${GITHUB_WORKSPACE:-/workspaces/{{ .Project.Metadata.Name }}}"

# Source helper scripts
source "$base_path/.devcontainer/scripts/copy_configs.sh"
source "$base_path/.devcontainer/scripts/set-docker-permissions.sh"

{{ if .Computed.HasNode -}}
# Pre-download package manager so Corepack doesn't prompt on first run (Node 24+ enables Corepack by default)
corepack enable
corepack prepare --activate
{{ end -}}

# Disable global git hooks in dev container
git config --global core.hooksPath /dev/null

# ---------------------------------------------------------------------------
# Fix volume permissions (volumes are mounted as root)
# ---------------------------------------------------------------------------
{{ if eq .Project.Spec.Cloud.Provider "gcp" -}}
if [ -d "/home/vscode/.config/gcloud" ]; then
    echo "🔐 Fixing gcloud config volume permissions..."
    sudo chown -R vscode:vscode /home/vscode/.config/gcloud
fi
{{ end -}}

if [ -d "/home/vscode/.claude" ]; then
    echo "🔐 Fixing Claude config volume permissions..."
    sudo chown -R vscode:vscode /home/vscode/.claude
fi

# ---------------------------------------------------------------------------
# Run setup functions
# ---------------------------------------------------------------------------
set_docker_permissions
copy_host_configs

# ---------------------------------------------------------------------------
# k3d cluster
# ---------------------------------------------------------------------------
CLUSTER_NAME="{{ .Project.Metadata.Name }}-cluster"
echo "🔧 Checking k3d cluster: ${CLUSTER_NAME}..."

if ! k3d cluster list | grep -q "${CLUSTER_NAME}"; then
    echo "🔧 Creating k3d cluster..."
    k3d cluster create --config .devcontainer/k3s/{{ .Project.Metadata.Name }}-cluster.config.yaml
else
    echo "✅ k3d cluster already exists"
fi

# Switch kubectl context
kubectl config use-context "k3d-${CLUSTER_NAME}" 2>/dev/null || true

# Create project namespace
kubectl create namespace {{ .Project.Metadata.Name }} --dry-run=client -o yaml | kubectl apply -f -
kubectl config set-context --current --namespace={{ .Project.Metadata.Name }}
{{ if .Computed.HasNode }}
# ---------------------------------------------------------------------------
# Node.js dependencies
# ---------------------------------------------------------------------------
echo "📦 Installing Node.js dependencies..."
{{ if eq .Project.Spec.Monorepo.PackageManager "yarn" -}}
yarn config set --home enableTelemetry 0 2>/dev/null || true
yarn install
{{ else -}}
pnpm install
{{ end -}}
{{ end -}}
{{ if .Computed.HasGo }}
# ---------------------------------------------------------------------------
# Go workspace
# ---------------------------------------------------------------------------
echo "📦 Syncing Go workspace..."
go work sync
{{ end }}
# ---------------------------------------------------------------------------
# Install iron CLI + shell completion
# ---------------------------------------------------------------------------
if command -v go &> /dev/null; then
    echo "📦 Installing iron CLI..."
    go install github.com/dag7/ironplate/cmd/iron@latest
    if command -v iron &> /dev/null; then
        COMPLETION_FOLDER="/home/vscode/.oh-my-zsh/completions"
        mkdir -p "$COMPLETION_FOLDER"
        iron completion zsh > "$COMPLETION_FOLDER/_iron"
        echo "✅ iron CLI installed with shell completion"
    fi
fi

echo ""
echo "✅ {{ .Project.Metadata.Name }} development environment is ready!"
echo ""
echo "Next steps:"
echo "  • Run 'tilt up' to start the development environment"
echo "  • Visit http://localhost:10350 for the Tilt dashboard"
echo ""
