// {{ .Project.Metadata.Name }} - Development Container Configuration
// Generated by ironplate
{
  "name": "{{ .Project.Metadata.Name }}",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "VARIANT": "jammy"
    }
  },
  "runArgs": [
    "--cpus=6",
    "--memory=24g",
    "--hostname=localhost",
    "--network=host",
    "--name=vsc-{{ .Project.Metadata.Name }}"
  ],
  "workspaceFolder": "/workspaces/{{ .Project.Metadata.Name }}",
  "containerEnv": {
    "HOST_PROJECT_ROOT": "${localWorkspaceFolder}",
    "DOCKER_BUILDKIT": "1"
  },
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind",
    "source=${localEnv:HOME}/.kube,target=/tmp/host/.kube,type=bind,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/tmp/host/.gitconfig,type=bind,readonly",
    "source=/etc/localtime,target=/etc/localtime,type=bind"{{ if eq .Project.Spec.Cloud.Provider "gcp" }},
    "source={{ .Project.Metadata.Name }}-gcloud-config,target=/home/vscode/.config/gcloud,type=volume"{{ end }}{{ if ne .Project.Spec.Cloud.Provider "none" }},
    "source=${localEnv:HOME}/.pulumi,target=/tmp/host/.pulumi,type=bind,readonly"{{ end }}
  ],
  "remoteEnv": {
    "SYNC_LOCALHOST_KUBECONFIG": "true",
    "KUBECONFIG": "/home/vscode/.kube/config"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "dev.containers.copyGitConfig": true{{ if .Computed.HasGo }},
        "go.useLanguageServer": true{{ end }}
      },
      "extensions": [
        "naumovs.color-highlight",
        "PKief.material-icon-theme",
        "redhat.vscode-yaml",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens",
        "github.vscode-pull-request-github",
        "mhutchie.git-graph",
        "streetsidesoftware.code-spell-checker",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "tilt-dev.tiltfile",
        "esbenp.prettier-vscode",
        "Anthropic.claude-code"{{ if .Computed.HasGo }},
        "golang.go"{{ end }}{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }},
        "GraphQL.vscode-graphql",
        "GraphQL.vscode-graphql-syntax"{{ end }}{{ if eq .Project.Spec.Infrastructure.Database.Type "postgresql" }},
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"{{ end }}
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-from-docker:1": {
      "version": "latest"
    }{{ if .Computed.HasNode }},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "{{ .Project.Spec.Monorepo.NodeVersion }}"
    }{{ end }}{{ if .Computed.HasGo }},
    "ghcr.io/devcontainers/features/go:1": {
      "version": "{{ .Project.Spec.Monorepo.GoVersion }}"
    }{{ end }},
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "forwardPorts": [
    5005,
    8081,
    10350{{ if eq .Project.Spec.Infrastructure.Database.Type "postgresql" }},
    5432{{ end }}{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }},
    8080{{ end }}
  ],
  "initializeCommand": "mkdir -p ${HOME}/.kube ${HOME}/.pulumi && [ -f ${HOME}/.gitconfig ] || touch ${HOME}/.gitconfig",
  "postCreateCommand": "chmod +x .devcontainer/scripts/post_cmd.sh && .devcontainer/scripts/post_cmd.sh",
  "remoteUser": "vscode"
}
