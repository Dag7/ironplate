# =============================================================================
# {{ .Project.Metadata.Name }} - Development Container
# =============================================================================
# Generated by ironplate
# =============================================================================
ARG VARIANT="jammy"
FROM mcr.microsoft.com/vscode/devcontainers/base:0-${VARIANT} AS base

ENV SHELL=/usr/bin/zsh \
    SECRETS_PINENTRY=default \
    PATH="/usr/local/kubectl:${PATH}"

# Install common dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl gnupg ca-certificates wget unzip software-properties-common \
    && rm -rf /var/lib/apt/lists/*
{{ if .Computed.HasNode }}
# Install python dependencies (required for node-gyp native modules)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libcairo2-dev pkg-config python3-dev && \
    rm -rf /var/lib/apt/lists/*
{{ if eq .Project.Spec.Monorepo.BuildSystem "nx" }}
# Install NX build system
RUN add-apt-repository ppa:nrwl/nx && \
    apt-get update && \
    apt-get install -y --no-install-recommends nx && \
    rm -rf /var/lib/apt/lists/*
{{ end }}
{{ end }}
# =============================================================================
# Core Kubernetes Tools
# =============================================================================

# kubectl
RUN ARCH="$(dpkg --print-architecture)" && \
    mkdir -p /usr/local/kubectl && \
    curl -sSL -o /usr/local/kubectl/kubectl \
      "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/${ARCH}/kubectl" && \
    chmod +x /usr/local/kubectl/kubectl && \
    ln -s /usr/local/kubectl/kubectl /usr/local/bin/kubectl

# Helm
RUN curl -s https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash

# k3d
RUN wget -q -O - https://raw.githubusercontent.com/k3d-io/k3d/main/install.sh | bash

# Tilt
RUN curl -sSL https://raw.githubusercontent.com/tilt-dev/tilt/master/scripts/install.sh | bash

# =============================================================================
# Database Clients
# =============================================================================
{{ if eq .Project.Spec.Infrastructure.Database.Type "postgresql" }}
# PostgreSQL client
RUN apt-get update && \
    apt-get install -y --no-install-recommends postgresql-client && \
    rm -rf /var/lib/apt/lists/*
{{ end }}
# =============================================================================
# Component-Specific Tools
# =============================================================================
{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }}
# Hasura CLI
RUN curl -L https://github.com/hasura/graphql-engine/raw/stable/cli/get.sh | bash
{{ end }}
{{ if .Project.Spec.GitOps.Enabled }}
# ArgoCD CLI
RUN ARCH="$(dpkg --print-architecture)" && \
    curl -sSL -o /usr/local/bin/argocd \
      "https://github.com/argoproj/argo-cd/releases/latest/download/argocd-linux-${ARCH}" && \
    chmod +x /usr/local/bin/argocd
{{ end }}
# =============================================================================
# Cloud Provider Tools
# =============================================================================
{{ if ne .Project.Spec.Cloud.Provider "none" }}
# Pulumi (Infrastructure as Code)
RUN curl -sSL https://get.pulumi.com | sh && \
    mv /root/.pulumi/bin/* /usr/local/bin/
{{ end }}
{{ if eq .Project.Spec.Cloud.Provider "gcp" }}
# Google Cloud SDK
RUN curl https://dl.google.com/dl/cloudsdk/release/google-cloud-sdk.tar.gz > /tmp/google-cloud-sdk.tar.gz && \
    mkdir -p /usr/local/gcloud && \
    tar -C /usr/local/gcloud -xvf /tmp/google-cloud-sdk.tar.gz && \
    /usr/local/gcloud/google-cloud-sdk/install.sh --quiet && \
    rm /tmp/google-cloud-sdk.tar.gz

ENV PATH=$PATH:/usr/local/gcloud/google-cloud-sdk/bin

# GKE auth plugin
RUN /usr/local/gcloud/google-cloud-sdk/bin/gcloud components install gke-gcloud-auth-plugin --quiet
{{ end }}
{{ if eq .Project.Spec.Cloud.Provider "aws" }}
# AWS CLI
RUN ARCH="$(uname -m)" && \
    if [ "$ARCH" = "aarch64" ]; then ARCH_SUFFIX="aarch64"; else ARCH_SUFFIX="x86_64"; fi && \
    curl "https://awscli.amazonaws.com/awscli-exe-linux-${ARCH_SUFFIX}.zip" -o "awscliv2.zip" && \
    unzip awscliv2.zip && \
    ./aws/install && \
    rm -rf awscliv2.zip aws

# eksctl
RUN ARCH="$(dpkg --print-architecture)" && \
    curl --silent --location \
      "https://github.com/weaveworks/eksctl/releases/latest/download/eksctl_$(uname -s)_${ARCH}.tar.gz" | \
      tar xz -C /tmp && \
    mv /tmp/eksctl /usr/local/bin
{{ end }}
# =============================================================================
# krew (kubectl plugin manager)
# =============================================================================
RUN set -x; cd "$(mktemp -d)" && \
    OS="$(uname | tr '[:upper:]' '[:lower:]')" && \
    ARCH="$(uname -m | sed -e 's/x86_64/amd64/' -e 's/\(arm\)\(64\)\?.*/\1\2/' -e 's/aarch64$/arm64/')" && \
    KREW="krew-${OS}_${ARCH}" && \
    curl -fsSLO "https://github.com/kubernetes-sigs/krew/releases/latest/download/${KREW}.tar.gz" && \
    tar zxvf "${KREW}.tar.gz" && \
    ./"${KREW}" install krew

# =============================================================================
# Shell Setup
# =============================================================================

# Create .config directory with proper ownership
RUN mkdir -p /home/vscode/.config && chown vscode:vscode /home/vscode/.config

# Completions
ENV COMPLETION_FOLDER="/home/vscode/.oh-my-zsh/completions"
RUN mkdir -p ${COMPLETION_FOLDER}

RUN echo "autoload -Uz compinit && compinit" >> /home/vscode/.zshrc

# kubectl completion
RUN kubectl completion zsh > ${COMPLETION_FOLDER}/_kubectl

# k3d completion
RUN k3d completion zsh > ${COMPLETION_FOLDER}/_k3d

# Helm completion
RUN helm completion zsh > ${COMPLETION_FOLDER}/_helm

# Tilt completion
RUN tilt completion zsh > ${COMPLETION_FOLDER}/_tilt
{{ if hasItem .Project.Spec.Infrastructure.Components "hasura" }}
# Hasura completion
RUN hasura completion zsh --file=${COMPLETION_FOLDER}/_hasura
{{ end }}
{{ if .Project.Spec.GitOps.Enabled }}
# ArgoCD completion
RUN argocd completion zsh > ${COMPLETION_FOLDER}/_argocd
{{ end }}
{{ if eq .Project.Spec.Cloud.Provider "gcp" }}
# gcloud completion
RUN echo "source /usr/local/gcloud/google-cloud-sdk/completion.zsh.inc" >> /home/vscode/.zshrc
{{ end }}
{{ if eq .Project.Spec.Cloud.Provider "aws" }}
# AWS completion
RUN echo "complete -C '/usr/local/bin/aws_completer' aws" >> /home/vscode/.zshrc

# eksctl completion
RUN eksctl completion zsh > ${COMPLETION_FOLDER}/_eksctl
{{ end }}
{{ if ne .Project.Spec.Cloud.Provider "none" }}
# Pulumi completion
RUN pulumi gen-completion zsh > ${COMPLETION_FOLDER}/_pulumi
{{ end }}
# Oh-my-zsh plugins
RUN sed -i "/^plugins=/c\plugins=(docker git kubectl history npm)" /home/vscode/.zshrc

# SSL workaround for Node.js
ENV OPENSSL_CONF=/dev/null

# Aliases
RUN echo "alias k=kubectl" >> /home/vscode/.zshrc && \
    echo "alias kn='kubectl config set-context --current --namespace'" >> /home/vscode/.zshrc
