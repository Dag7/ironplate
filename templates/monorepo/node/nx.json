{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.test.ts"
    ],
    "prod": ["default"]
  },
  "parallel": 3,
  "cacheDirectory": "./.nx/cache",
  "useDaemonProcess": true,
  "targetDefaults": {
    "build": {
      "configurations": {
        "prod": {
          "tsconfig": "{projectRoot}/tsconfig.build.json"
        }
      },
      "inputs": ["prod"],
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "test": {
      "outputs": ["{projectRoot}/coverage"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "prettier": {
      "cache": true
    },
    "prettier:fix": {
      "cache": true
    }
  },
  "plugins": []
}
