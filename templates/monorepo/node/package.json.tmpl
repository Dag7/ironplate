{
  "name": "{{ .Project.Metadata.Name }}",
  "version": "1.0.0",
  "private": true,
  "packageManager": "{{ .Project.Spec.Monorepo.PackageManager }}@4.13.0",
  "engines": {
    "node": ">={{ .Project.Spec.Monorepo.NodeVersion }}.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/node/*"
  ],
  "scripts": {
    "dev": "tilt up",
    "build:all": "npx nx run-many --target=build --all",
    "build:packages:tsc": "npx nx run-many --target=build --all --exclude='apps/*'",
    "watch:packages:tsc": "npx nx run-many --target=build --all --exclude='apps/*' --watch",
    "watch:packages": "nx watch --all -- nx build \\$NX_PROJECT_NAME",
    "test": "npx nx run-many --target=test --all",
    "test:all": "vitest run --workspace vitest.workspace.ts",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:coverage": "vitest run --workspace vitest.workspace.ts --coverage",
    "test:coverage:html": "vitest run --workspace vitest.workspace.ts --coverage && echo '\\n📊 Coverage report: file://$(pwd)/coverage/index.html'",
    "test:coverage:summary": "vitest run --workspace vitest.workspace.ts --coverage --reporter=basic",
    "lint": "npx nx run-many --target=lint --all",
    "lint:fix": "npx nx run-many --target=lint --all -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,yaml,yml,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,yaml,yml,md}\"",
    "typecheck": "npx nx run-many --target=typecheck --all",
    "clean:dist": "find . -name 'dist' -type d -not -path '*/node_modules/*' -exec rm -rf {} +",
    "clean:node_modules": "find . -name 'node_modules' -type d -exec rm -rf {} +",
    "nx:graph": "npx nx graph",
    "nx:logs": "npx nx view-logs",
    "nx:cleanup": "npx nx reset",
{{- if eq .Project.Spec.DevEnvironment.K8sLocal "k3d" }}
    "k3d:create": "k3d cluster create --config .devcontainer/k3s/cluster-config.yaml",
    "k3d:delete": "k3d cluster delete {{ .Project.Metadata.Name }}-cluster",
    "k3d:start": "k3d cluster start {{ .Project.Metadata.Name }}-cluster",
    "k3d:stop": "k3d cluster stop {{ .Project.Metadata.Name }}-cluster",
{{- end }}
    "tilt:up": "tilt up",
    "tilt:down": "tilt down"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@nx/js": "^22.1.3",
    "@nx/vite": "^22.1.3",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.18.0",
    "globals": "^16.0.0",
    "nx": "^22.1.3",
    "prettier": "^3.6.2",
    "tsx": "^4.7.0",
    "typescript": "6.0.2",
    "typescript-eslint": "^8.20.0",
    "vitest": "^1.6.1"
  }
}
