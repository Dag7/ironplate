{
  "name": "@ironplate/tilt-manager",
  "version": "0.0.1",
  "license": "MIT",
  "description": "CLI tool for managing Tilt profiles in monorepo projects",
  "repository": {
    "type": "git",
    "url": "https://github.com/dag7/ironplate.git",
    "directory": "packages/node/tilt-manager"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:nx": "nx build",
    "watch": "tsc -p tsconfig.build.json --watch",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "inquirer": "^8.2.6",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
